---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  backgroundImage = "/electricianimgs/jimmy-nilsson-masth-UovTD1dG-lA-unsplash.jpg",
} = Astro.props;

// Generate breadcrumb from URL path
const currentPath = Astro.url.pathname;
const pathSegments = currentPath.split('/').filter(Boolean);

let breadcrumb = "Home";
if (pathSegments.length > 0) {
  // Map category slugs to display names
  const categoryMap: Record<string, string> = {
    'commercial-electrical': 'Commercial Electrical Service',
    'residential-electrical': 'Residential Electrical Service',
    'specialty-electrical': 'Specialty Electrical Service',
    'emergency-electrical': 'Emergency Electrical Service',
  };
  
  const breadcrumbParts = ['Home'];
  
  // Add parent category if exists
  if (pathSegments.length >= 1) {
    const parentCategory = pathSegments[0];
    if (categoryMap[parentCategory]) {
      breadcrumbParts.push(categoryMap[parentCategory]);
    }
  }
  
  // Add current page (convert slug to title case)
  if (pathSegments.length >= 2) {
    const currentPage = pathSegments[pathSegments.length - 1]
      .split('-')
      .map(word => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ');
    breadcrumbParts.push(currentPage);
  }
  
  breadcrumb = breadcrumbParts.join(' / ');
}
---

<section class="hero-subpage relative w-full overflow-hidden">

  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img 
      src={backgroundImage} 
      alt="" 
      class="hero-bg"
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/60 to-black/40"></div>
  </div>

  <!-- Content - Left aligned -->
  <div class="relative z-10 w-full pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="container mx-auto px-4">

      <!-- Left-aligned content -->
      <div class="max-w-4xl">
        <p class="hero-breadcrumb text-xs md:text-sm font-medium text-white/90 mb-4">
          {breadcrumb}
        </p>

        <h1 class="hero-h1 text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-white mb-4">
          {title}
        </h1>

        {subtitle && (
          <p class="hero-sub text-sm md:text-base text-white/85 max-w-2xl leading-relaxed">
            {subtitle}
          </p>
        )}
      </div>

    </div>
  </div>
</section>

<style>
  .hero-subpage {
    min-height: 35vh;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  /* Hide background image on mobile (below 768px) */
  @media (max-width: 767px) {
    .hero-bg {
      display: none;
    }
    
    .hero-subpage {
      background: linear-gradient(135deg, #1a2332 0%, #2c3e50 100%);
    }
  }

  .hero-breadcrumb {
    animation: fadeUp 0.6s ease both;
    letter-spacing: 0.05em;
  }
  
  .hero-h1 {
    animation: fadeUp 0.7s ease 0.1s both;
    line-height: 1.2;
  }
  
  .hero-sub {
    animation: fadeUp 0.7s ease 0.2s both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-breadcrumb, .hero-h1, .hero-sub { animation: none; }
  }

  @media (max-width: 768px) {
    .hero-subpage {
      min-height: 30vh;
    }
  }
</style>
