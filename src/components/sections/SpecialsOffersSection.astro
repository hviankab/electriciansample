---
interface Coupon {
  label: string
  discount: string
  description: string
  expires?: string
  image?: string
  ribbonText?: string
}

interface Props {
  title?: string
  subtitle?: string
  coupons: Coupon[]
}

const { 
  title = "Current Specials & Offers",
  subtitle = "Save on quality electrical services with our exclusive deals",
  coupons 
} = Astro.props
---

<section class="py-16 bg-gradient-to-b from-gray-50 to-white">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <!-- Coupons Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {coupons.map((coupon) => (
        <div class="coupon-card relative bg-white rounded-xl shadow-lg hover:shadow-2xl transition-shadow duration-300 overflow-visible border-[3px] border-dashed border-blue-600 group flex flex-col h-full">
          
          <!-- Ribbon Badge - Redesigned -->
          {coupon.ribbonText && (
            <div class="absolute -top-2 -right-2 z-20">
              <div class="bg-red-600 text-white text-[11px] font-extrabold px-3 py-1.5 rounded-md shadow-xl border-2 border-white">
                <span class="uppercase tracking-wide whitespace-nowrap">{coupon.ribbonText}</span>
              </div>
            </div>
          )}

          <!-- Card Content -->
          <div class="p-6 text-center relative flex flex-col flex-1">
            
            <!-- Label -->
            {coupon.label && (
              <div class="text-sm font-bold text-gray-800 mb-3 uppercase tracking-wide">
                {coupon.label}
              </div>
            )}

            <!-- Image (if provided) -->
            {coupon.image && (
              <div class="mb-4 flex justify-center">
                <img src={coupon.image} alt={coupon.discount} class="h-24 w-auto object-contain" />
              </div>
            )}

            <!-- Discount -->
            <div class="mb-4">
              <div class="text-4xl md:text-5xl font-black text-blue-500 leading-tight mb-2" style="-webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;">
                {coupon.discount}
              </div>
            </div>

            <!-- Description -->
            <p class="text-gray-700 text-sm leading-relaxed mb-4 flex-1">
              {coupon.description}
            </p>

            <!-- Expires -->
            {coupon.expires && (
              <p class="text-xs text-gray-500 italic mb-3 font-medium">
                Expires: {coupon.expires}
              </p>
            )}

            <!-- CTA Button -->
            <a 
              href="/contact" 
              class="inline-block bg-brand-secondary hover:bg-brand-highlight text-gray-900 hover:text-gray-900 font-bold px-6 py-2.5 rounded-full transition-colors shadow-md text-sm uppercase tracking-wide"
            >
              Claim Offer
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Disclaimer -->
    <div class="mt-12 text-center">
      <p class="text-sm text-gray-500 max-w-3xl mx-auto">
        *Offers cannot be combined with other promotions or discounts. Some restrictions may apply. 
        Contact us for complete details and to verify eligibility.
      </p>
    </div>
  </div>
</section>

<style>
  .coupon-card {
    position: relative;
  }

  /* Prevent ribbon overflow issues */
  .coupon-card {
    overflow: visible !important;
  }

  .ribbon {
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
  }
</style>