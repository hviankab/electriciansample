---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  description: string;
  image?: string;
  stats?: Array<{
    number: string;
    label: string;
  }>;
}

const {
  eyebrow = "COMMERCIAL ELECTRICAL",
  title,
  subtitle,
  description,
  image = "/electricianimgs/male-electrician-working-electrical-panel-male-electrician-overalls.jpg",
  stats = [
    { number: "500+", label: "Projects Completed" },
    { number: "27+", label: "Years Experience" },
    { number: "100%", label: "Licensed & Insured" }
  ]
} = Astro.props;
---

<section class="commercial-intro">
  <div class="commercial-container">
    
    <div class="content-wrapper">
      <!-- Left: Content -->
      <div class="text-content">
        <div class="eyebrow-text">{eyebrow}</div>
        
        <h2 class="main-title">{title}</h2>
        
        {subtitle && (
          <p class="subtitle-text">{subtitle}</p>
        )}
        
        <p class="description-text">{description}</p>
        
        <!-- Stats -->
        <div class="stats-grid">
          {stats.map((stat) => (
            <div class="stat-item">
              <div class="stat-number">{stat.number}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Image -->
      <div class="image-wrapper">
        <img src={image} alt={title} loading="lazy" />
        <div class="image-overlay"></div>
      </div>
    </div>

  </div>
</section>

<style>
  .commercial-intro {
    padding: 5rem 2rem;
    background: #ffffff;
  }

  .commercial-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .eyebrow-text {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #000000;
  }

  .main-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.2;
    margin: 0;
  }

  .subtitle-text {
    font-size: 1.25rem;
    font-weight: 600;
    color: #333333;
    line-height: 1.4;
    margin: 0;
  }

  .description-text {
    font-size: 1rem;
    color: #4a4a4a;
    line-height: 1.7;
    margin: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 2px solid #f0f0f0;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #666666;
    font-weight: 500;
  }

  .image-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4/5;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 50%);
  }

  @media (max-width: 1024px) {
    .content-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .stats-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .commercial-intro {
      padding: 4rem 1.5rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .stat-item {
      text-align: center;
    }
  }
</style>
