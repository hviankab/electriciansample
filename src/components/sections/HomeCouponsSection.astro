---
import { getLocationText, siteConfig } from "@/config/site"

interface Props {
  title?: string;
  coupons?: any[];
}

const {
  title: rawTitle = "Special Offers",
  coupons,
} = Astro.props;

const title = getLocationText(rawTitle);

// Clean, professional coupon data
const offers = [
  {
    discount: "$100",
    discountText: "OFF",
    ribbonText: "$100 OFF",
    ribbonSubtext: "",
    title: "$100 off on Air Duct Cleaning",
    description: "$100 off NADCA Certified Whole Home Air Duct Cleaning",
    code: "NEW100",
    image: "/newimages/download - 2026-03-25T161755.081.avif"
  },
  {
    discount: "$50",
    discountText: "OFF",
    ribbonText: "$50 OFF",
    ribbonSubtext: "",
    title: "Save $50 on Any Repair",
    description: "Repair service in hours, not days. Save $50 on any heating and cooling repair services.",
    code: "REPAIR150",
    image: "/newimages/download - 2026-03-25T161815.066.avif"
  },
  {
    discount: "$95",
    discountText: "OFF",
    ribbonText: "$95 OFF",
    ribbonSubtext: "",
    title: "$95 on Your Furnace Tune-Up!",
    description: "$95 on a Furnace Tune-up. Regularly $150",
    code: "MAINT25",
    image: "/newimages/download - 2026-03-25T161826.922.avif"
  }
];
---

<section class="home-coupons-section">
  <div class="container mx-auto px-4">
    <!-- Clean Header -->
    <div class="section-header">
      <h2 class="section-title">Limited Time Offers</h2>
      <p class="section-subtitle">Save on professional HVAC services</p>
    </div>

    <!-- Coupon Grid -->
    <div class="coupons-grid">
      {offers.map((offer, index) => (
        <div class="coupon-card" data-index={index}>
          <!-- Discount Ribbon -->
          <div class="discount-ribbon">
            <div class="ribbon-content">
              {offer.ribbonText && <span class="ribbon-text">{offer.ribbonText}</span>}
              {offer.ribbonSubtext && <span class="ribbon-subtext">{offer.ribbonSubtext}</span>}
            </div>
          </div>

          <!-- Image Section -->
          <div class="card-image">
            <img src={offer.image} alt={offer.title} />
          </div>
          
          <!-- Content -->
          <div class="card-content">
            <h3 class="offer-title">{offer.title}</h3>
            <p class="offer-description">{offer.description}</p>
            
            <div class="card-footer">
              <span class="promo-code">Code: {offer.code}</span>
              <a href="/contact" class="coupon-book-btn inline-flex items-center justify-center gap-2 bg-brand-secondary text-white px-8 py-4 rounded-full font-semibold text-base transition-all shadow-lg hover:shadow-xl">
                Book Now
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .home-coupons-section {
    background: 
      linear-gradient(135deg, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.90) 100%),
      url('/newimages/download - 2026-03-25T161836.070.avif') center/cover no-repeat fixed;
    padding: 5rem 0;
    position: relative;
  }

  /* Header */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 800;
    color: white;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    font-weight: 400;
  }

  /* Grid */
  .coupons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 20px;
  }

  /* Card */
  .coupon-card {
    background: white;
    border-radius: 12px;
    overflow: visible;
    position: relative;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 
      0 4px 24px rgba(0, 0, 0, 0.12),
      0 2px 8px rgba(0, 0, 0, 0.08);
    margin-top: 30px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .coupon-card:hover {
    transform: translateY(-10px);
    box-shadow: 
      0 20px 48px rgba(0, 0, 0, 0.2),
      0 8px 16px rgba(0, 0, 0, 0.12);
  }

  /* Image Section */
  .card-image {
    position: relative;
    height: 240px;
    overflow: hidden;
    background: #f1f5f9;
    border-radius: 4px 4px 0 0;
    flex-shrink: 0;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .coupon-card:hover .card-image img {
    transform: scale(1.05);
  }

  /* Discount Ribbon */
  .discount-ribbon {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
  }

  .ribbon-content {
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    color: white;
    text-align: center;
    padding: 14px 40px;
    border-radius: 50px;
    box-shadow: none;
    transform: none;
    position: relative;
    width: auto;
    white-space: nowrap;
  }

  .ribbon-text {
    display: inline;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-shadow: none;
    line-height: 1;
    margin: 0;
  }

  .ribbon-subtext {
    display: none;
  }

  /* Content */
  .card-content {
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  /* Title */
  .offer-title {
    font-size: 1.625rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
    min-height: 3.5rem;
  }

  /* Description */
  .offer-description {
    font-size: 1.0625rem;
    color: #475569;
    line-height: 1.7;
    margin: 0;
    flex: 1;
    font-weight: 400;
    min-height: 3.5rem;
  }

  /* Footer */
  .card-footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
    margin-top: auto;
  }

  .promo-code {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #dc2626;
    font-family: 'Courier New', monospace;
    letter-spacing: 0.08em;
    background: rgba(220, 38, 38, 0.08);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    display: inline-block;
    border: 1px dashed rgba(220, 38, 38, 0.3);
  }

  /* Custom button hover - mint green with black text */
  .coupon-book-btn:hover {
    background-color: #A9E5BB !important;
    color: #000000 !important;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .coupons-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 500px;
    }

    .section-title {
      font-size: 2.5rem;
    }

    .card-content {
      padding: 1.75rem 1.5rem;
    }

    .card-image {
      height: 220px;
    }
  }

  @media (max-width: 768px) {
    .home-coupons-section {
      padding: 3rem 0;
    }

    .section-header {
      margin-bottom: 2.5rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .section-subtitle {
      font-size: 1rem;
    }

    .card-image {
      height: 200px;
    }

    .discount-ribbon {
      top: -16px;
    }

    .ribbon-content {
      padding: 10px 28px;
    }

    .ribbon-text {
      font-size: 1rem;
      letter-spacing: 0.04em;
    }

    .offer-title {
      font-size: 1.25rem;
    }

    .offer-description {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .card-content {
      padding: 1.5rem 1.25rem;
      gap: 1rem;
    }

    .coupon-card {
      margin-top: 25px;
    }

    .card-image {
      height: 180px;
    }

    .discount-ribbon {
      top: -10px;
    }

    .ribbon-content {
      padding: 8px 20px;
    }

    .ribbon-text {
      font-size: 0.8rem;
      letter-spacing: 0.03em;
    }

    .promo-code {
      font-size: 0.875rem;
      padding: 0.4rem 0.875rem;
    }
  }
</style>
