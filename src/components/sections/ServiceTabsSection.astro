---
interface ServiceTab {
  title: string;
  description: string;
  image: string;
  points: string[];
  buttonText?: string;
  buttonHref?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  description?: string;
  tabs?: ServiceTab[];
}

const {
  eyebrow = "OUR SERVICES",
  title = "Services You Can",
  subtitle = "Depend On",
  description = "We provide comprehensive electrical solutions for commercial construction projects of all sizes.",
  tabs = [
    {
      title: "Ground-Up Construction",
      description: "Complete electrical systems for new commercial buildings from initial design to final inspection.",
      image: "/electricianimgs/electrician-working-near-board-with-wires-installation-connection-electrics.jpg",
      points: ["Complete Electrical Design & Engineering", "Power Distribution & Panel Installation", "Code Compliance & Permit Management"],
      buttonText: "Schedule Service",
      buttonHref: "/contact"
    }
  ]
} = Astro.props;
---

<section class="service-tabs-section">
  <div class="service-tabs-container">
    <!-- Header -->
    <div class="tabs-header">
      <p class="tabs-eyebrow">{eyebrow}</p>
      <h2 class="tabs-title">{title} <span class="tabs-subtitle">{subtitle}</span></h2>
      <p class="tabs-description">{description}</p>
    </div>

    <!-- Tab Buttons -->
    <div class="tabs-nav" role="tablist">
      {tabs.map((tab, i) => (
        <button
          class={`tab-btn ${i === 0 ? 'active' : ''}`}
          data-tab={i}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          <span class="tab-plus">+</span>
          <span class="tab-label">{tab.title}</span>
        </button>
      ))}
    </div>

    <!-- Tab Panels -->
    <div class="tabs-content">
      {tabs.map((tab, i) => (
        <div class={`tab-panel ${i === 0 ? 'active' : ''}`} data-panel={i} role="tabpanel">
          <div class="panel-grid">
            <div class="panel-text">
              <h3 class="panel-title">{tab.title}</h3>
              <p class="panel-description">{tab.description}</p>
              <ul class="panel-points">
                {tab.points.map((point) => (
                  <li>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
              <a href={tab.buttonHref || "/contact"} class="panel-btn">
                {tab.buttonText || "Schedule Service"}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="panel-image">
              <img src={tab.image} alt={tab.title} loading="lazy" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-tabs-section {
    padding: 6rem 2rem;
    background: #ffffff;
  }

  .service-tabs-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Header */
  .tabs-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .tabs-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 1rem 0;
  }

  .tabs-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .tabs-subtitle {
    display: block;
  }

  .tabs-description {
    font-size: 1rem;
    color: #6b7280;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Tab nav */
  .tabs-nav {
    display: flex;
    gap: 0;
    margin-bottom: 3rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    flex-wrap: wrap;
  }

  .tab-btn {
    flex: 1;
    min-width: 150px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    background: #ffffff;
    border: none;
    border-right: 1px solid #e5e7eb;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    text-align: left;
    transition: all 0.2s ease;
    line-height: 1.3;
  }

  .tab-btn:last-child {
    border-right: none;
  }

  .tab-btn:hover {
    background: #f9fafb;
    color: #000000;
  }

  .tab-btn.active {
    background: #1a2332;
    color: #ffffff;
  }

  .tab-plus {
    font-size: 1.25rem;
    font-weight: 300;
    flex-shrink: 0;
    line-height: 1;
  }

  .tab-btn.active .tab-plus {
    color: #FFD700;
  }

  /* Tab panels */
  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .panel-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #000000;
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .panel-description {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.7;
    margin: 0 0 1.5rem 0;
  }

  .panel-points {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .panel-points li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #374151;
    font-weight: 500;
  }

  .panel-points svg {
    color: #FFD700;
    flex-shrink: 0;
  }

  .panel-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    color: #000000;
    border: none;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .panel-btn:hover {
    background: #000000;
    color: #ffffff;
  }

  .panel-image {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .panel-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .panel-grid { grid-template-columns: 1fr; gap: 2rem; }
    .panel-image { order: -1; }
    .tabs-nav { flex-wrap: wrap; }
    .tab-btn { flex: 1 1 calc(50% - 1px); min-width: 0; }
  }

  @media (max-width: 768px) {
    .service-tabs-section { padding: 4rem 1.5rem; }
    .tab-btn { flex: 1 1 100%; border-right: none; border-bottom: 1px solid #e5e7eb; padding: 0.875rem 1rem; font-size: 0.875rem; }
    .tab-btn:last-child { border-bottom: none; }
    .panel-title { font-size: 1.5rem; }
  }

  @media (max-width: 480px) {
    .service-tabs-section { padding: 3rem 1rem; }
    .tabs-header { margin-bottom: 2rem; }
  }
</style>

<script>
  function initTabs() {
    const btns = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-tab');
        btns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        panels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        document.querySelector(`.tab-panel[data-panel="${idx}"]`)?.classList.add('active');
      });
    });
  }

  initTabs();
  document.addEventListener('astro:page-load', initTabs);
</script>
