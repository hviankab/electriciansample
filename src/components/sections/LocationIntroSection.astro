---
interface Props {
  eyebrow?: string;
  title: string;
  location: string;
  description: string;
  image?: string;
  serviceAreas?: string[];
  features?: Array<{
    icon: string;
    title: string;
    description: string;
  }>;
}

const {
  eyebrow = "SERVICE AREA",
  title,
  location,
  description,
  image = "/electricianimgs/male-electrician-working-electrical-panel-male-electrician-overalls.jpg",
  serviceAreas = [],
  features = [
    { icon: "⚡", title: "Fast Response", description: "Same-day service available throughout the area" },
    { icon: "🏆", title: "Licensed & Insured", description: "Fully certified electricians you can trust" },
    { icon: "🕐", title: "24/7 Emergency", description: "Available anytime for urgent electrical issues" }
  ]
} = Astro.props;
---

<section class="location-intro">
  <div class="location-container">
    
    <div class="location-grid">
      <!-- Left: Content -->
      <div class="content-area">
        <div class="location-eyebrow">{eyebrow}</div>
        
        <h2 class="location-title">{title}</h2>
        
        <div class="location-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span>Serving {location}</span>
        </div>
        
        <p class="location-description">{description}</p>
        
        <!-- Features Grid -->
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card">
              <div class="feature-icon">{feature.icon}</div>
              <div class="feature-content">
                <h3 class="feature-title">{feature.title}</h3>
                <p class="feature-desc">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
        
        {serviceAreas.length > 0 && (
          <div class="service-areas">
            <h3 class="areas-title">Areas We Serve:</h3>
            <div class="areas-list">
              {serviceAreas.map((area) => (
                <span class="area-tag">{area}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right: Image -->
      <div class="image-area">
        <div class="image-container">
          <img src={image} alt={`Electrical services in ${location}`} loading="lazy" />
          <div class="image-overlay"></div>
          
          <!-- Floating Badge -->
          <div class="floating-badge">
            <div class="badge-icon">⚡</div>
            <div class="badge-text">
              <div class="badge-title">Licensed Electricians</div>
              <div class="badge-subtitle">Serving {location}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .location-intro {
    padding: 5rem 2rem;
    background: #ffffff;
  }

  .location-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .location-grid {
    display: grid;
    grid-template-columns: 55% 45%;
    gap: 4rem;
    align-items: center;
  }

  .content-area {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .location-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #000000;
  }

  .location-title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.2;
    margin: 0;
  }

  .location-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    border-radius: 50px;
    width: fit-content;
  }

  .location-badge svg {
    color: #000000;
  }

  .location-badge span {
    font-size: 0.875rem;
    font-weight: 700;
    color: #000000;
  }

  .location-description {
    font-size: 1rem;
    color: #4a4a4a;
    line-height: 1.7;
    margin: 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: #f8f9fa;
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    background: #f0f0f0;
  }

  .feature-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .feature-content {
    flex: 1;
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: #000000;
    margin: 0 0 0.25rem 0;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: #666666;
    line-height: 1.5;
    margin: 0;
  }

  .service-areas {
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 2px solid #f0f0f0;
  }

  .areas-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: #000000;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .areas-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .area-tag {
    padding: 0.5rem 1rem;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 20px;
    font-size: 0.875rem;
    color: #333333;
    font-weight: 500;
  }

  .image-area {
    position: relative;
  }

  .image-container {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4/5;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
  }

  .floating-badge {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .badge-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .badge-text {
    flex: 1;
  }

  .badge-title {
    font-size: 1rem;
    font-weight: 700;
    color: #000000;
    margin-bottom: 0.25rem;
  }

  .badge-subtitle {
    font-size: 0.875rem;
    color: #666666;
  }

  @media (max-width: 1024px) {
    .location-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .image-container {
      aspect-ratio: 16/10;
    }
  }

  @media (max-width: 768px) {
    .location-intro {
      padding: 4rem 1.5rem;
    }

    .features-grid {
      gap: 1rem;
    }

    .feature-card {
      padding: 1rem;
    }

    .floating-badge {
      bottom: 1rem;
      left: 1rem;
      right: 1rem;
      padding: 1rem;
    }
  }
</style>
