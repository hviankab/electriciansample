---
interface Props {
  badge: string;
  title: string;
  description: string;
  highlights: string[];
  serviceArea: string;
  guaranteeText: string;
  infoBoxText: string;
  buttonText: string;
  buttonHref: string;
  image: string;
  imageAlt?: string;
}

const {
  badge,
  title,
  description,
  highlights,
  serviceArea,
  guaranteeText,
  infoBoxText,
  buttonText,
  buttonHref,
  image,
  imageAlt = "HVAC Service"
} = Astro.props;
---

<section class="py-20" style="background-color: #f7f7f7;">
  <div class="container mx-auto px-4">
    <div class="max-w-7xl mx-auto">
      
      <!-- Header Section -->
      <div class="text-center mb-16">
        <div class="eyebrow justify-center">
          <span>SERVICE AREAS</span>
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          {title}
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed max-w-5xl mx-auto">
          {description}
        </p>
      </div>

      <!-- Main Content: Image + Why Choose Us -->
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        
        <!-- Left: Image -->
        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img
              src={image}
              alt={imageAlt}
              class="w-full h-[500px] object-cover"
            />
          </div>
        </div>

        <!-- Right: Why Choose Us -->
        <div class="space-y-8">
          <h3 class="text-3xl font-bold text-gray-900">
            Why Choose Us
          </h3>

          <!-- Feature List -->
          <div class="space-y-8">
            
            <!-- Feature 1: Urban Expertise -->
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0">
                <img src="/images/air-conditioning.png" alt="" class="w-8 h-8" />
              </div>
              <div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">Urban Expertise</h4>
                <p class="text-gray-600 leading-relaxed">
                  High-rise buildings and compact spaces present unique HVAC challenges. Our team specializes in delivering tailored solutions to fit the needs of your space.
                </p>
              </div>
            </div>

            <!-- Feature 2: Comprehensive Services -->
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0">
                <img src="/images/heating.png" alt="" class="w-8 h-8" />
              </div>
              <div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">Comprehensive Services</h4>
                <p class="text-gray-600 leading-relaxed">
                  From system installations to emergency repairs, we offer a full range of heating, cooling, and air quality services.
                </p>
              </div>
            </div>

            <!-- Feature 3: Customer-Focused Approach -->
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0">
                <img src="/images/headphones-with-mic.png" alt="" class="w-8 h-8" />
              </div>
              <div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">Customer-Focused Approach</h4>
                <p class="text-gray-600 leading-relaxed">
                  We prioritize your satisfaction with prompt responses, transparent pricing, and reliable service.
                </p>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .cta-btn:hover {
    background-color: #A9E5BB !important;
    color: #1a1a1a !important;
  }
</style>
