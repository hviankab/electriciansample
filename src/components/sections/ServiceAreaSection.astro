---
import { siteConfig, getLocationText } from "@/config/site"

interface Props {
  title: string;
  description: string;
  areas?: string[];
  mapImage?: string;
  mapEmbed?: string;
  mapAddress?: string;
  variant?: "full" | "compact";
  buttonText?: string;
  buttonHref?: string;
}

const {
  title: rawTitle,
  description: rawDescription,
  areas: rawAreas,
  mapImage,
  mapEmbed,
  mapAddress = `${siteConfig.location.city}, ${siteConfig.location.state}`,
  variant = "full",
  buttonText = "SERVICE AREAS",
  buttonHref = "/service-areas"
} = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const areas = rawAreas ? rawAreas.map(getLocationText) : undefined;

const getMapEmbedUrl = (address: string) => {
  const encodedAddress = encodeURIComponent(address);
  return `https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=${encodedAddress}&zoom=14`;
};

const embedUrl = mapEmbed || (mapAddress ? getMapEmbedUrl(mapAddress) : null);
---

{variant === "compact" ? (
  <!-- ============ COMPACT ============ -->
  <section class="sa-section py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="sa-compact-wrap rounded-3xl border-2 border-white overflow-hidden max-w-[1100px] mx-auto" data-animate="fade-up">
        <div class="grid md:grid-cols-2">
          
          <!-- Map side -->
          <div class="sa-map-side relative min-h-[280px] md:min-h-[360px]">
            {embedUrl ? (
              <iframe
                src={embedUrl}
                width="100%"
                height="100%"
                style="border:0; position:absolute; inset:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Service Area Map"
              ></iframe>
            ) : mapImage ? (
              <img src={mapImage} alt="Service Area Map" class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 bg-brand-tertiary flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-brand-secondary/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
            )}
          </div>

          <!-- Content side -->
          <div class="p-8 md:p-10 flex flex-col justify-center bg-card">
            <div class="sa-pin-badge inline-flex items-center gap-2 self-start mb-5 px-4 py-2 rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span class="text-sm font-semibold uppercase tracking-wider">Service Area</span>
            </div>

            <h2 class="text-2xl md:text-3xl font-bold mb-4">{title}</h2>
            <p class="text-base text-muted-foreground leading-relaxed mb-6" set:html={description} />

            <a
              href={buttonHref}
              class="sa-btn inline-flex items-center gap-3 self-start rounded-full px-6 py-3 font-semibold text-base transition-all"
            >
              {buttonText}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
) : (
  <!-- ============ FULL ============ -->
  <section class="sa-section sa-full py-20 md:py-28">
    <div class="container mx-auto px-4">
      
      <!-- Header left-aligned -->
      <div class="mb-8" data-animate="fade-up">
        <div class="eyebrow">
          <span>OUR LOCATION</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
        <p class="text-base text-muted-foreground leading-relaxed mb-6 max-w-4xl">
          We cover a wide range of locations throughout New York, ensuring high-quality HVAC services are always nearby when you need them. Our main service areas include but are not limited to:
        </p>
        
        {/* Tabs for areas - Single line with chevrons */}
        {areas && areas.length > 0 && (
          <div class="sa-tabs-wrapper">
            <button 
              type="button" 
              class="chevron-btn chevron-left" 
              aria-label="Previous locations"
              onclick="document.querySelector('.sa-tabs-container').scrollLeft -= 300; console.log('LEFT CLICKED');"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M15 18l-6-6 6-6"/>
              </svg>
            </button>
            
            <div class="sa-tabs-container">
              <div class="sa-tabs">
                {areas.map((area, index) => (
                  <button 
                    type="button"
                    class={`sa-tab ${index === 0 ? 'sa-tab-active' : ''}`}
                    data-area={area}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                      <circle cx="12" cy="10" r="3" fill="white"/>
                    </svg>
                    {area}
                  </button>
                ))}
              </div>
            </div>

            <button 
              type="button" 
              class="chevron-btn chevron-right" 
              aria-label="Next locations"
              onclick="document.querySelector('.sa-tabs-container').scrollLeft += 300; console.log('RIGHT CLICKED');"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>
          </div>
        )}
      </div>

      <!-- Large Map -->
      <div class="sa-map-container" data-animate="fade-up">
        <div class="sa-map-frame-large">
          <iframe
            id="service-area-map"
            src={embedUrl}
            width="100%"
            height="100%"
            style="border:0; position:absolute; inset:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Service Area Map"
          ></iframe>
          <a 
            id="map-open-link"
            href={`https://www.google.com/maps?q=${encodeURIComponent(mapAddress)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="sa-map-link"
          >
            Open in Maps
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Details below map -->
      <div class="sa-details-grid" data-animate="fade-up">
        <div class="sa-detail-item">
          <div class="sa-detail-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="sa-detail-content">
            <p class="sa-detail-text">{siteConfig.location.fullAddress}</p>
            <p class="sa-detail-text">{siteConfig.location.city}, {siteConfig.location.state}</p>
          </div>
        </div>

        <div class="sa-detail-item">
          <div class="sa-detail-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="sa-detail-content">
            <p class="sa-detail-text">Monday to Saturday: 8:00 AM - 6:00 PM</p>
            <p class="sa-detail-text">Sunday: 10:00 AM - 4:00 PM</p>
          </div>
        </div>

        <div class="sa-detail-item">
          <div class="sa-detail-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
          <div class="sa-detail-content">
            <p class="sa-detail-text">AC Repair & Installation</p>
            <p class="sa-detail-text">Heating, Cooling & Emergency Services</p>
          </div>
        </div>

        <div class="sa-detail-item">
          <div class="sa-detail-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M2 12h20"/>
            </svg>
          </div>
          <div class="sa-detail-content">
            <p class="sa-detail-text">24/7 Emergency Service Available</p>
            <p class="sa-detail-text">Licensed & Insured Technicians</p>
          </div>
        </div>
      </div>

      <!-- Description below map -->
      {description && (
        <div class="mt-8 max-w-4xl" data-animate="fade-up">
          <p class="text-base text-muted-foreground leading-relaxed" set:html={description} />
        </div>
      )}

    </div>
  </section>
)}

<style>
  .sa-section {
    background: white;
  }

  .sa-full {
    background: white;
  }

  /* Tabs Wrapper with Chevrons */
  .sa-tabs-wrapper {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .chevron-btn {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border: 2px solid #e2e8f0;
    border-radius: 50%;
    color: #1e3a8a;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 100;
    pointer-events: auto;
    position: relative;
  }

  .chevron-btn:hover:not(:disabled) {
    background: #1e3a8a;
    color: white;
    border-color: #1e3a8a;
  }

  .chevron-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .chevron-btn svg {
    width: 1.5rem;
    height: 1.5rem;
    pointer-events: none;
  }

  /* Tabs Container - Single line, no wrap */
  .sa-tabs-container {
    flex: 1;
    overflow-x: scroll;
    overflow-y: hidden;
    position: relative;
    z-index: 1;
    padding: 0.5rem 0;
    scroll-behavior: smooth;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }

  .sa-tabs-container::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .sa-tabs {
    display: flex;
    gap: 0.5rem;
    padding: 0.25rem 0;
  }

  .sa-tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: transparent;
    border: none;
    color: #64748b;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sa-tab:hover {
    color: #1e293b;
  }

  .sa-tab-active {
    color: #dc2626;
  }

  .sa-tab svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* Map container */
  .sa-map-container {
    position: relative;
    border: 2px solid #e2e8f0;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .sa-map-frame-large {
    position: relative;
    width: 100%;
    height: 500px;
  }

  .sa-map-link {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e3a8a;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    z-index: 10;
  }

  .sa-map-link:hover {
    background: #1e3a8a;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(30, 58, 138, 0.3);
  }

  /* Details grid below map */
  .sa-details-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }

  .sa-detail-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .sa-detail-icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #dc2626;
  }

  .sa-detail-icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .sa-detail-content {
    flex: 1;
  }

  .sa-detail-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0;
  }

  .sa-detail-text:first-child {
    font-weight: 600;
    color: #1e293b;
  }

  @media (max-width: 1024px) {
    .sa-details-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .sa-map-frame-large {
      height: 350px;
    }

    .chevron-btn {
      width: 2.5rem;
      height: 2.5rem;
    }

    .chevron-btn svg {
      width: 1.25rem;
      height: 1.25rem;
    }

    .sa-details-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>

<script is:inline>
  (function() {
    function initServiceAreaTabs() {
      console.log('=== INIT SERVICE AREA TABS ===');
      
      const tabs = document.querySelectorAll('.sa-tab');
      const mapIframe = document.getElementById('service-area-map');
      const mapLink = document.getElementById('map-open-link');
      const tabsContainer = document.querySelector('.sa-tabs-container');
      const leftChevron = document.querySelector('.chevron-left');
      const rightChevron = document.querySelector('.chevron-right');

      console.log('Elements found:', {
        tabs: tabs.length,
        mapIframe: !!mapIframe,
        tabsContainer: !!tabsContainer,
        leftChevron: !!leftChevron,
        rightChevron: !!rightChevron
      });

      if (!tabs.length || !mapIframe) {
        console.error('Required elements not found');
        return;
      }

      // Handle tab clicks
      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          tabs.forEach(function(t) { t.classList.remove('sa-tab-active'); });
          tab.classList.add('sa-tab-active');

          const area = tab.getAttribute('data-area');
          
          if (area) {
            const encodedArea = encodeURIComponent(area + ', CA');
            const newMapUrl = 'https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=' + encodedArea + '&zoom=14';
            mapIframe.src = newMapUrl;

            if (mapLink) {
              mapLink.href = 'https://www.google.com/maps?q=' + encodedArea;
            }
          }
        });
      });

      // Handle chevron navigation
      if (leftChevron && rightChevron && tabsContainer) {
        console.log('Setting up chevron handlers');
        
        leftChevron.onclick = function(e) {
          console.log('LEFT CHEVRON CLICKED!');
          e.preventDefault();
          e.stopPropagation();
          tabsContainer.scrollLeft -= 300;
          return false;
        };

        rightChevron.onclick = function(e) {
          console.log('RIGHT CHEVRON CLICKED!');
          e.preventDefault();
          e.stopPropagation();
          tabsContainer.scrollLeft += 300;
          return false;
        };

        console.log('Chevron handlers attached');
      } else {
        console.error('Chevron setup failed - missing elements');
      }
    }

    // Run immediately if DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initServiceAreaTabs);
    } else {
      setTimeout(initServiceAreaTabs, 100);
    }
    
    // Re-initialize on Astro page transitions
    document.addEventListener('astro:page-load', function() {
      setTimeout(initServiceAreaTabs, 100);
    });
  })();
</script>
