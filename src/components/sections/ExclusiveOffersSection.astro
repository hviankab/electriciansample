---
interface Props {
  title?: string
  description?: string
  phoneNumber?: string
  phoneDisplay?: string
}

const { 
  title = "Exclusive Specials & Offers – Save on Your HVAC Services!",
  description = "At ABC Company, we believe in making home comfort affordable for everyone. Check out our limited-time offers and special promotions on HVAC services, maintenance plans, and installations. Whether you need a tune-up, repair, or upgrade, we've got a deal that's right for you. Don't miss out—these offers won't last long!",
  phoneNumber = "0123456789",
  phoneDisplay = "012-345-6789"
} = Astro.props
---

<section class="py-16 md:py-20" style="background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 50%, #2563eb 100%);">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center">
      
      <!-- Title -->
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
        {title}
      </h2>
      
      <!-- Description -->
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed mb-8 max-w-3xl mx-auto">
        {description}
      </p>
      
      <!-- Call to Action -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 text-lg md:text-xl text-blue-100">
        <span>Call us today at</span>
        <a 
          href={`tel:${phoneNumber}`}
          class="font-bold text-brand-secondary hover:text-brand-highlight transition-colors duration-300 underline decoration-2 underline-offset-4"
        >
          {phoneDisplay}
        </a>
        <span>to take advantage of our current specials!</span>
      </div>
      
    </div>
  </div>
</section>

<style>
  /* Ensure proper text contrast */
  section {
    color: white;
  }
  
  /* Responsive text sizing */
  @media (max-width: 640px) {
    h2 {
      font-size: 1.875rem; /* text-3xl */
      line-height: 1.2;
    }
    
    p {
      font-size: 1rem; /* text-base */
    }
    
    .flex > span {
      font-size: 1rem; /* text-base */
    }
  }
  
  /* Phone number hover effect */
  a[href^="tel:"]:hover {
    text-decoration-thickness: 3px;
  }
</style>