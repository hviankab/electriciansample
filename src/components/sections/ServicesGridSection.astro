---
interface Service {
  title: string;
  description: string;
  image: string;
  icon: string;
  href: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  services?: Service[];
}

const {
  title = "Delivering Every Project",
  subtitle = "With Precision",
  description = "Industry-standard services for safety, functionality, and long-lasting reliability.",
  services = [
    {
      title: "Electrical Wiring & Repair",
      description: "Expert rewiring, updates, and troubleshooting for residential and commercial properties.",
      image: "/electricianimgs/anton-dmitriev-kBKOaghy8mU-unsplash.jpg",
      icon: "⚡",
      href: "/services/wiring-repair"
    },
    {
      title: "Commercial Installation",
      description: "Power distribution and lighting systems for medium to large-scale facilities.",
      image: "/electricianimgs/electrician-working-near-board-with-wires-installation-connection-electrics.jpg",
      icon: "🏢",
      href: "/services/commercial"
    },
    {
      title: "Lighting Design & Setup",
      description: "Energy-saving LED lighting that transforms your space.",
      image: "/electricianimgs/jimmy-nilsson-masth-U3GiK1u5j24-unsplash.jpg",
      icon: "💡",
      href: "/services/lighting"
    },
    {
      title: "Electrical Maintenance",
      description: "Regular check-ups to keep your systems running safely.",
      image: "/electricianimgs/jimmy-nilsson-masth-UovTD1dG-lA-unsplash.jpg",
      icon: "🔧",
      href: "/services/maintenance"
    }
  ]
} = Astro.props;
---

<section class="services-grid-section">
  <div class="services-container">
    <!-- Centered Header -->
    <div class="services-header">
      <h2 class="services-title">
        {title}
        {subtitle && <span class="services-subtitle"> {subtitle}</span>}
      </h2>
      <p class="services-description">{description}</p>
    </div>

    <!-- Service Cards Grid -->
    <div class="services-grid">
      {services.map((service) => (
        <a href={service.href} class="service-card">
          <div class="service-image-wrapper">
            <img src={service.image} alt={service.title} loading="lazy" />
            <div class="service-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
          <div class="service-content">
            <h3 class="service-title">{service.title}</h3>
            <p class="service-description">{service.description}</p>
            <span class="service-link-text">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid-section {
    padding: 6rem 2rem;
    background: #0a0a0a;
    position: relative;
    overflow: hidden;
  }

  .services-grid-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/electricianimgs/electrician-working-near-board-with-wires-installation-connection-electrics.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.1;
    z-index: 0;
  }

  .services-container {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Centered header */
  .services-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 4rem;
  }

  .services-title {
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
  }

  .services-subtitle {
    color: #FFD700;
  }

  .services-description {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    margin: 0;
  }

  /* Cards grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.3);
    border-color: #FFD700;
  }

  .service-image-wrapper {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .service-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .service-card:hover .service-image-wrapper img {
    transform: scale(1.05);
  }

  .service-icon {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 42px;
    height: 42px;
    background: #FFD700;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-icon svg { color: #000000; }

  .service-content {
    padding: 1.25rem 1.5rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #000000;
    margin: 0;
    line-height: 1.3;
  }

  .service-description {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .service-link-text {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.5rem;
    transition: gap 0.2s ease;
  }

  .service-card:hover .service-link-text {
    gap: 0.625rem;
    color: #FFA500;
  }

  @media (max-width: 1200px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }  @media (max-width: 768px) {
    .services-grid-section { padding: 4rem 1.5rem; }
    .services-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .service-image-wrapper { height: 180px; }
  }
</style>
