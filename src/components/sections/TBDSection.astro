// TBD Section - Placeholder for future content
---

<section class="tbd-section">
  <div class="container mx-auto px-4">
    <div class="tbd-content">
      <h2 class="tbd-title">TO BE DETERMINED</h2>
      
      <!-- Decorative Divider with Icon -->
      <div class="tbd-divider">
        <span class="divider-line"></span>
        <svg class="divider-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        <span class="divider-line"></span>
      </div>
      
      <p class="tbd-description">BASED ON THE CLIENT DISCOVERY CONVERSATION</p>
    </div>
  </div>
</section>

<style>
  .tbd-section {
    padding: 12rem 0;
    background: white;
  }

  .tbd-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .tbd-title {
    font-size: 3.5rem;
    font-weight: 700;
    color: #1e3a8a;
    margin: 0 0 1.5rem 0;
    letter-spacing: 0.05em;
  }

  /* Decorative Divider */
  .tbd-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 0 auto 1.5rem;
    max-width: 400px;
  }

  .divider-line {
    flex: 1;
    height: 2px;
    background: #1e3a8a;
  }

  .divider-icon {
    width: 2rem;
    height: 2rem;
    color: #1e3a8a;
    flex-shrink: 0;
  }

  .tbd-description {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1e3a8a;
    margin: 0;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .tbd-section {
      padding: 3rem 0;
    }

    .tbd-title {
      font-size: 1.75rem;
    }

    .tbd-description {
      font-size: 0.875rem;
    }

    .divider-icon {
      width: 1.5rem;
      height: 1.5rem;
    }
  }
</style>
