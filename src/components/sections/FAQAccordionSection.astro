---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  image?: string;
  faqs?: FAQ[];
}

const {
  eyebrow = "FAQ'S",
  title = "Frequently Asked Questions About Our Services and Process",
  description = "Find clear answers to common questions about our services, pricing, safety standards, and how we handle your electrical projects.",
  image = "/electricianimgs/AdobeStock_136089970.jpeg",
  faqs = [
    {
      question: "Do you provide emergency electrical services?",
      answer: "Yes, we offer fast and reliable emergency services to handle urgent electrical issues and restore safety as quickly as possible. Pricing depends on the project scope, but we always provide clear, upfront quotes with no hidden charges. We provide complete electrical solutions for homes, offices, and commercial spaces of all sizes."
    },
    {
      question: "Are your electricians certified and insured?",
      answer: "Yes, all our electricians are fully licensed, certified, and insured to provide safe and professional electrical services."
    },
    {
      question: "How much do your services cost?",
      answer: "Our pricing varies based on the scope of work. We provide transparent quotes with no hidden fees after assessing your project."
    },
    {
      question: "Do you handle both residential and commercial projects?",
      answer: "Yes, we work on both residential and commercial electrical projects of all sizes, from small repairs to large installations."
    },
    {
      question: "How quickly can I schedule a service?",
      answer: "We offer flexible scheduling and can often accommodate same-day or next-day appointments depending on availability."
    },
    {
      question: "When Should You Upgrade Your Electrical Panel?",
      answer: "You should upgrade your electrical panel if you're experiencing frequent breaker trips, adding new appliances, or if your panel is over 25 years old."
    }
  ]
} = Astro.props;
---

<section class="faq-section">
  <div class="faq-container">
    <div class="faq-layout">
      <!-- Left: Header & Image -->
      <div class="faq-header">
        <p class="faq-eyebrow">{eyebrow}</p>
        <h2 class="faq-title">{title}</h2>
        <p class="faq-description">{description}</p>
        <div class="faq-image">
          <img src={image} alt="Electrician at work" loading="lazy" />
        </div>
      </div>

      <!-- Right: FAQ Items -->
      <div class="faq-list">
        {faqs.map((faq, index) => (
          <details class="faq-item" open={index === 0}>
            <summary class="faq-question">
              <span>{faq.question}</span>
              <div class="faq-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path class="icon-minus" d="M5 12h14"/>
                  <path class="icon-plus" d="M12 5v14"/>
                </svg>
              </div>
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 5rem 2rem;
    background: #ffffff;
  }

  .faq-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .faq-layout {
    display: grid;
    grid-template-columns: 450px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .faq-header {
    position: sticky;
    top: 120px;
  }

  .faq-eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1rem 0;
    display: block;
  }

  .faq-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800;
    color: #000000;
    line-height: 1.2;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
  }

  .faq-description {
    font-size: 0.9375rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0 0 2rem 0;
  }

  .faq-image {
    width: 100%;
    height: 280px;
    border-radius: 12px;
    overflow: hidden;
  }

  .faq-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    background: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    transition: all 0.2s ease;
  }

  .faq-item:first-child {
    border-top: 1px solid #e5e7eb;
  }

  .faq-item[open] {
    background: #ffffff;
  }

  .faq-question {
    padding: 1.5rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: #000000;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    list-style: none;
    user-select: none;
    transition: all 0.2s ease;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question:hover {
    color: #FFD700;
  }

  .faq-item[open] .faq-question {
    color: #FFD700;
  }

  .faq-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .faq-icon svg {
    color: #9ca3af;
    transition: all 0.2s ease;
  }

  .faq-item[open] .faq-icon svg {
    color: #FFD700;
  }

  .faq-item[open] .icon-plus {
    display: none;
  }

  .faq-item:not([open]) .icon-minus {
    display: none;
  }

  .faq-answer {
    padding: 0 0 1.5rem 0;
    color: #6b7280;
    font-size: 0.9375rem;
    line-height: 1.7;
    animation: slideDown 0.3s ease;
  }

  .faq-answer p {
    margin: 0;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .faq-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .faq-header {
      position: static;
    }
    .faq-image { height: 240px; }
  }

  @media (max-width: 768px) {
    .faq-section { padding: 4rem 1.5rem; }
    .faq-question { font-size: 1rem; padding: 1.25rem 0; gap: 1rem; }
    .faq-answer { padding: 0 0 1.25rem 0; font-size: 0.9rem; }
    .faq-image { height: 200px; }
  }

  @media (max-width: 480px) {
    .faq-section { padding: 3rem 1rem; }
    .faq-question { font-size: 0.9rem; }
  }
</style>
