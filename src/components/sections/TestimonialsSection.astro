---
interface Testimonial {
  name: string;
  role: string;
  image: string;
  rating: number;
  content: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  mainImage?: string;
  testimonials?: Testimonial[];
}

const {
  eyebrow = "TESTIMONIALS",
  title = "Trusted by Clients for Quality Electrical Work and Reliable Service",
  description = "See what our clients say about our professionalism, fast response, and high quality electrical solutions delivered with safety and care.",
  mainImage = "/electricianimgs/AdobeStock_136089970.jpeg",
  testimonials = [
    {
      name: "William S.",
      role: "Happy Client",
      image: "/electricianimgs/anton-dmitriev-kBKOaghy8mU-unsplash.jpg",
      rating: 5,
      content: "Highly professional and quick service. They fixed our wiring issue fast and ensured everything was safe. Very reliable team and great experience overall. The team upgraded our electrical panel smoothly. Transparent pricing and no hidden costs. Solved everything efficiently and professionally."
    },
    {
      name: "Michael R.",
      role: "Happy Client",
      image: "/electricianimgs/emmanuel-ikwuegbu--0-kl1BjvFc-unsplash.jpg",
      rating: 5,
      content: "Highly professional and quick service. They fixed our wiring issue fast and ensured everything was safe. Very reliable team and great experience overall. The team upgraded our electrical panel smoothly. Transparent pricing and no hidden costs. Solved everything efficiently and professionally."
    }
  ]
} = Astro.props;
---

<section class="testimonials-section">
  <div class="testimonials-container">
    <!-- Header -->
    <div class="testimonials-header">
      <p class="testimonials-eyebrow">{eyebrow}</p>
      <h2 class="testimonials-title">{title}</h2>
      <p class="testimonials-description">{description}</p>
    </div>

    <!-- Content Grid -->
    <div class="testimonials-grid">
      <!-- Left: Main Image -->
      <div class="main-image">
        <img src={mainImage} alt="Electrician at work" loading="lazy" />
      </div>

      <!-- Right: Testimonial Cards -->
      <div>
        <div class="testimonials-cards">
          {testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <div class="card-stars">
                {Array.from({ length: 5 }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              
              <div class="card-header">
                <img src={testimonial.image} alt={testimonial.name} class="client-avatar" />
                <div class="client-info">
                  <h3 class="client-name">{testimonial.name}</h3>
                  <p class="client-role">{testimonial.role}</p>
                </div>
                <div class="quote-mark">
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                  </svg>
                </div>
              </div>
              
              <p class="testimonial-text">{testimonial.content}</p>
            </div>
          ))}
        </div>
        
        <!-- Navigation Dots -->
        <div class="navigation-dots">
          <button class="dot dot-active" aria-label="Testimonial 1"></button>
          <button class="dot" aria-label="Testimonial 2"></button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 5rem 2rem;
    background: #ffffff;
  }

  .testimonials-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .testimonials-eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1rem 0;
  }

  .testimonials-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #000000;
    line-height: 1.2;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .testimonials-description {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .main-image {
    width: 100%;
    height: 450px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
  }

  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials-cards {
    background: #f3f4f6;
    padding: 2.5rem;
    border-radius: 16px;
    display: block;
    position: relative;
    min-height: 350px;
  }

  .testimonial-card {
    background: #ffffff;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    position: relative;
    display: none;
  }

  .testimonial-card:first-child {
    display: block;
  }

  .card-stars {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .card-stars svg {
    color: #FFD700;
    width: 18px;
    height: 18px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    position: relative;
  }

  .client-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .client-info {
    flex: 1;
  }

  .client-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: #000000;
    margin: 0 0 0.25rem 0;
  }

  .client-role {
    font-size: 0.9375rem;
    color: #000000;
    font-style: italic;
    margin: 0;
  }

  .quote-mark {
    flex-shrink: 0;
    position: absolute;
    right: 0;
    top: -0.5rem;
  }

  .quote-mark svg {
    color: #000000;
    opacity: 0.15;
    width: 48px;
    height: 48px;
  }

  .testimonial-text {
    font-size: 0.9375rem;
    color: #4b5563;
    line-height: 1.7;
    margin: 0;
  }

  .navigation-dots {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.2);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: rgba(0, 0, 0, 0.4);
  }

  .dot-active {
    background: #FFD700;
  }

  @media (max-width: 1024px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .main-image {
      height: 400px;
    }

    .testimonials-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .testimonials-section {
      padding: 4rem 1.5rem;
    }

    .main-image {
      height: 300px;
    }

    .testimonials-cards {
      padding: 2rem 1.5rem;
      grid-template-columns: 1fr;
    }

    .testimonial-card {
      padding: 1.5rem;
    }
  }
</style>

<script>
  function initTestimonialCarousel() {
    const cards = document.querySelectorAll('.testimonial-card');
    const dots = document.querySelectorAll('.navigation-dots .dot');
    
    if (cards.length === 0 || dots.length === 0) return;
    
    let currentIndex = 0;
    const totalSlides = cards.length;
    
    // Function to show specific slide
    function showSlide(index: number) {
      // Hide all cards
      cards.forEach((card) => {
        (card as HTMLElement).style.display = 'none';
      });
      
      // Remove active class from all dots
      dots.forEach((dot) => {
        dot.classList.remove('dot-active');
      });
      
      // Show current card
      (cards[index] as HTMLElement).style.display = 'block';
      
      // Activate current dot
      dots[index].classList.add('dot-active');
    }
    
    // Function to go to next slide
    function nextSlide() {
      currentIndex = (currentIndex + 1) % totalSlides;
      showSlide(currentIndex);
    }
    
    // Add click handlers to dots
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        currentIndex = index;
        showSlide(currentIndex);
      });
    });
    
    // Show first slide initially
    showSlide(0);
    
    // Auto-advance every 5 seconds (infinite loop)
    setInterval(nextSlide, 5000);
  }
  
  // Initialize on page load
  initTestimonialCarousel();
  
  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initTestimonialCarousel);
</script>
