---
import { getLocationText } from "@/config/site"

interface Testimonial {
  name: string;
  initials: string;
  date: string;
  rating: number;
  content: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  testimonials: Testimonial[];
}

const { badge = "TESTIMONIALS", title: rawTitle, description: rawDescription, testimonials: rawTestimonials } = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
const testimonials = rawTestimonials.map(t => ({ ...t, content: getLocationText(t.content) }));
---

<section class="testimonials-section">
  <div class="testimonials-container">
    <!-- Header -->
    <div class="testimonials-header">
      <div class="badge-wrapper">
        <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        <span>{badge}</span>
      </div>
      
      <h2 class="testimonials-title">{title}</h2>
      {description && (
        <p class="testimonials-description">{description}</p>
      )}
    </div>

    <!-- Testimonials Grid -->
    <div class="testimonials-grid">
      {testimonials.map((testimonial, index) => (
        <div class="testimonial-card" data-index={index}>
          <div class="card-header">
            <div class="avatar">
              <span class="avatar-text">{testimonial.initials}</span>
            </div>
            <div class="user-info">
              <div class="user-name">{testimonial.name}</div>
              <div class="user-date">{testimonial.date}</div>
            </div>
            <div class="rating">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg 
                  class={`star ${i < testimonial.rating ? 'star-filled' : 'star-empty'}`}
                  viewBox="0 0 24 24" 
                  fill={i < testimonial.rating ? "currentColor" : "none"}
                  stroke="currentColor" 
                  stroke-width="2"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
          </div>
          
          <div class="card-content">
            <div class="quote-icon">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
              </svg>
            </div>
            <p class="testimonial-text" set:html={testimonial.content} />
          </div>
        </div>
      ))}
    </div>

    <!-- Navigation Dots -->
    <div class="navigation-dots">
      {testimonials.map((_, index) => (
        <button 
          class={`dot ${index === 0 ? 'dot-active' : ''}`}
          data-index={index}
          aria-label={`Go to testimonial ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    position: relative;
  }

  .testimonials-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .testimonials-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .badge-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: linear-gradient(135deg, rgba(247, 179, 43, 0.1), rgba(247, 179, 43, 0.05));
    border: 1px solid rgba(247, 179, 43, 0.2);
    border-radius: 50px;
    margin-bottom: 1.5rem;
  }

  .badge-icon {
    width: 1rem;
    height: 1rem;
    stroke: #F7B32B;
  }

  .badge-wrapper span {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #D97706;
  }

  .testimonials-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .testimonials-description {
    font-size: 1.125rem;
    color: #64748b;
    line-height: 1.7;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Grid */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  /* Card */
  .testimonial-card {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e2e8f0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  .testimonial-card[data-index="0"] { animation-delay: 0.1s; }
  .testimonial-card[data-index="1"] { animation-delay: 0.2s; }
  .testimonial-card[data-index="2"] { animation-delay: 0.3s; }
  .testimonial-card[data-index="3"] { animation-delay: 0.4s; }
  .testimonial-card[data-index="4"] { animation-delay: 0.5s; }
  .testimonial-card[data-index="5"] { animation-delay: 0.6s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .testimonial-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    border-color: #F7B32B;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .avatar {
    width: 3rem;
    height: 3rem;
    background: linear-gradient(135deg, #124E66, #0f3e52);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .avatar-text {
    font-size: 1rem;
    font-weight: 700;
    color: white;
  }

  .user-info {
    flex: 1;
  }

  .user-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
  }

  .user-date {
    font-size: 0.875rem;
    color: #94a3b8;
    margin-top: 0.125rem;
  }

  .rating {
    display: flex;
    gap: 0.25rem;
  }

  .star {
    width: 1rem;
    height: 1rem;
  }

  .star-filled {
    color: #F7B32B;
  }

  .star-empty {
    color: #e2e8f0;
  }

  .card-content {
    position: relative;
  }

  .quote-icon {
    position: absolute;
    top: -0.5rem;
    left: -0.5rem;
    width: 2rem;
    height: 2rem;
    color: #F7B32B;
    opacity: 0.2;
  }

  .testimonial-text {
    font-size: 0.95rem;
    color: #475569;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  /* Navigation Dots */
  .navigation-dots {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }

  .dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: #cbd5e1;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: #94a3b8;
    transform: scale(1.2);
  }

  .dot-active {
    background: #F7B32B;
    width: 2rem;
    border-radius: 1rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .testimonials-section {
      padding: 4rem 0;
    }

    .testimonials-container {
      padding: 0 1rem;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .testimonial-card {
      padding: 1.5rem;
    }
  }
</style>

<script>
  // Optional: Add carousel functionality if needed
  function initTestimonials() {
    const dots = document.querySelectorAll('.dot');
    const cards = document.querySelectorAll('.testimonial-card');

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        // Update active dot
        dots.forEach(d => d.classList.remove('dot-active'));
        dot.classList.add('dot-active');

        // Scroll to card (optional enhancement)
        cards[index]?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });
  }

  initTestimonials();
  document.addEventListener('astro:page-load', initTestimonials);
</script>
