---
interface Testimonial {
  name: string;
  role: string;
  image?: string;
  initials?: string;
  rating: number;
  content: string;
  date?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  testimonials?: Testimonial[];
}

const {
  eyebrow = "TESTIMONIALS",
  title = "What Our Clients",
  subtitle = "Are Saying",
  testimonials = [
    { name: "William S.", role: "Homeowner", initials: "WS", rating: 5, date: "2 weeks ago", content: "Highly professional and quick service. They fixed our wiring issue fast and ensured everything was safe. Very reliable team and great experience overall." },
    { name: "Michael R.", role: "Business Owner", initials: "MR", rating: 5, date: "1 month ago", content: "The team upgraded our electrical panel smoothly. Transparent pricing and no hidden costs. Solved everything efficiently and professionally. Highly recommend!" },
    { name: "Sarah J.", role: "Property Manager", initials: "SJ", rating: 5, date: "3 weeks ago", content: "Called them for an emergency at 11 PM and they were at my property within 45 minutes. Fixed the problem quickly and professionally. Outstanding service!" },
    { name: "David C.", role: "Restaurant Owner", initials: "DC", rating: 5, date: "1 week ago", content: "Installed EV charging stations and upgraded our entire lighting system. Clean work, fair pricing, and they explained everything clearly. Will use again!" },
    { name: "Lisa M.", role: "Homeowner", initials: "LM", rating: 5, date: "2 months ago", content: "Best electricians I've worked with. They upgraded our electrical panel and added new circuits. Very knowledgeable, professional, and on time every visit." },
    { name: "Robert T.", role: "Contractor", initials: "RT", rating: 5, date: "3 weeks ago", content: "Used them for our commercial project. They handled everything from permits to final inspection. Couldn't be happier with the quality and professionalism." },
    { name: "Jennifer L.", role: "Homeowner", initials: "JL", rating: 5, date: "1 week ago", content: "Great experience! They installed recessed lighting throughout our home. The quality of work is outstanding and the price was very reasonable. Highly recommend!" },
    { name: "Carlos M.", role: "Property Owner", initials: "CM", rating: 5, date: "2 weeks ago", content: "Fast, reliable, and very professional. They rewired our entire office and the job was done perfectly. Will definitely call them again for future projects." },
    { name: "Amanda K.", role: "Business Owner", initials: "AK", rating: 5, date: "3 weeks ago", content: "Excellent service from start to finish. The electricians were on time, clean, and very knowledgeable. Fixed our panel issue quickly and at a fair price." }
  ]
} = Astro.props;

// Group testimonials into slides of 3
const slides: typeof testimonials[] = [];
for (let i = 0; i < testimonials.length; i += 3) {
  slides.push(testimonials.slice(i, i + 3));
}
---

<section class="testimonials-section">
  <div class="testimonials-header">
    <p class="testimonials-eyebrow">{eyebrow}</p>
    <h2 class="testimonials-title">{title} {subtitle}</h2>

    <!-- Google rating badge -->
    <div class="google-badge">
      <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      <div class="badge-stars">
        {[1,2,3,4,5].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        ))}
      </div>
      <span class="badge-text">4.9 / 5 &nbsp;·&nbsp; 200+ Google Reviews</span>
    </div>
  </div>

  <div class="testimonials-container">
    <!-- Slider -->
    <div class="slider-wrapper">
      <div class="slider-track" id="sliderTrack">
        {slides.map((slide) => (
          <div class="slide">
            {slide.map((t) => (
              <div class="testimonial-card">
                <div class="card-top">
                  <div class="card-stars">
                    {Array.from({ length: t.rating }).map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="#FFD700"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <svg class="quote-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                  </svg>
                </div>
                <p class="card-content">"{t.content}"</p>
                <div class="card-footer">
                  <div class="client-avatar">
                    {t.image ? <img src={t.image} alt={t.name} /> : <span>{t.initials}</span>}
                  </div>
                  <div class="client-info">
                    <span class="client-name">{t.name}</span>
                    <span class="client-role">{t.role}</span>
                  </div>
                  {t.date && <span class="card-date">{t.date}</span>}
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- Controls: dots only -->
    <div class="carousel-controls">
      <div class="carousel-dots" id="carouselDots">
        {slides.map((_, i) => (
          <button class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Slide ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 6rem 2rem;
    background: #f5f5f5;
  }

  .testimonials-header {
    max-width: 1280px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .testimonials-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 1rem 0;
  }

  .testimonials-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.2;
    margin: 0 0 2rem 0;
    font-family: 'Barlow', system-ui, sans-serif;
  }

  /* Google badge */
  .google-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 50px;
    padding: 0.625rem 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .badge-stars {
    display: flex;
    gap: 2px;
  }

  .badge-text {
    font-size: 0.875rem;
    color: #374151;
    font-weight: 600;
  }

  /* Slider */
  .testimonials-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .slider-wrapper {
    overflow: hidden;
  }

  .slider-track {
    display: flex;
    transition: transform 0.4s ease;
  }

  .slide {
    flex: 0 0 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding: 0.25rem;
  }

  .testimonial-card {
    background: #ffffff;
    border-radius: 12px;
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 2px solid #e5e7eb;
    transition: box-shadow 0.2s ease;
  }

  .testimonial-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-stars { display: flex; gap: 2px; }

  .quote-icon { color: #d1d5db; }

  .card-content {
    font-size: 0.95rem;
    color: #374151;
    line-height: 1.7;
    margin: 0;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid #f3f4f6;
  }

  .client-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .client-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .client-avatar span { font-size: 0.8rem; font-weight: 800; color: #000000; }

  .client-info { flex: 1; display: flex; flex-direction: column; gap: 0.1rem; }
  .client-name { font-size: 0.9rem; font-weight: 700; color: #000000; }
  .client-role { font-size: 0.78rem; color: #6b7280; }
  .card-date { font-size: 0.75rem; color: #9ca3af; white-space: nowrap; }

  /* Controls */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
  }

  .carousel-dots { display: flex; gap: 0.5rem; }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d1d5db;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  .carousel-dot.active { background: #000000; width: 24px; border-radius: 4px; }

  @media (max-width: 768px) {
    .testimonials-section { padding: 4rem 1.5rem; }
    .testimonial-card { padding: 1.5rem; }
    .slide { grid-template-columns: 1fr; }
  }

  @media (max-width: 1024px) and (min-width: 769px) {
    .slide { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  function initSlider() {
    const track = document.getElementById('sliderTrack') as HTMLElement;
    const dots = document.querySelectorAll('.carousel-dot');
    if (!track) return;

    const slides = track.querySelectorAll('.slide');
    const total = slides.length;
    let current = 0;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    let timer = setInterval(() => goTo(current + 1), 5000);
    track.addEventListener('mouseenter', () => clearInterval(timer));
    track.addEventListener('mouseleave', () => { timer = setInterval(() => goTo(current + 1), 5000); });

    goTo(0);
  }

  initSlider();
  document.addEventListener('astro:page-load', initSlider);
</script>
