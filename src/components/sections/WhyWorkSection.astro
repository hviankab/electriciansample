---
import { getLocationText } from "@/config/site"

interface Reason {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  reasons: Reason[];
}

const { badge = "WHY JOIN US", title: rawTitle, reasons } = Astro.props;

const title = getLocationText(rawTitle);
---

<section class="why-work-section">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="section-header" data-animate="fade-up">
      <div class="eyebrow justify-center">
        <span>{badge}</span>
      </div>
      <h2 class="section-title">{title}</h2>
    </div>

    <!-- Reasons Grid -->
    <div class="reasons-grid" data-animate-stagger>
      {reasons.map((reason) => (
        <div class="reason-card">
          <div class="icon-wrapper">
            <span class="icon">{reason.icon}</span>
          </div>
          <h3 class="reason-title">{reason.title}</h3>
          <p class="reason-description">{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-work-section {
    padding: 5rem 0;
    background: #f7f7f7;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #000001;
    line-height: 1.2;
    margin: 0;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .reason-card {
    grid-column: span 2;
  }

  .reason-card:nth-child(4),
  .reason-card:nth-child(5) {
    grid-column: span 3;
  }

  .reason-card {
    background: white;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    text-align: center;
    transition: all 0.3s ease;
  }

  .reason-card:hover {
    border-color: #F7B32B;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .icon-wrapper {
    width: 80px;
    height: 80px;
    background: #fef3e2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .icon {
    font-size: 2.5rem;
  }

  .reason-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #000001;
    margin: 0 0 1rem 0;
    line-height: 1.3;
  }

  .reason-description {
    font-size: 1rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .reasons-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .reason-card,
    .reason-card:nth-child(4),
    .reason-card:nth-child(5) {
      grid-column: span 1;
    }
  }

  @media (max-width: 768px) {
    .why-work-section {
      padding: 4rem 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .reasons-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
