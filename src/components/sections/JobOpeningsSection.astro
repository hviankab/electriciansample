---
interface Job {
  title: string;
  type: string;
  responsibilities: string;
  buttonText?: string;
  buttonHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  jobs: Job[];
}

const { badge = "CAREERS", title, jobs } = Astro.props;
---

<section class="job-openings-section">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="section-header" data-animate="fade-up">
      <div class="eyebrow justify-center">
        <span>{badge}</span>
      </div>
      <h2 class="section-title">{title}</h2>
    </div>

    <!-- Job Cards Grid -->
    <div class="jobs-grid" data-animate-stagger>
      {jobs.map((job) => (
        <div class="job-card">
          <h3 class="job-title">{job.title}</h3>
          <p class="job-type">{job.type}</p>
          <p class="job-responsibilities">{job.responsibilities}</p>
          {job.buttonText && job.buttonHref && (
            <a href={job.buttonHref} class="job-button">
              {job.buttonText}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .job-openings-section {
    padding: 5rem 0;
    background: #f7f7f7;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #000001;
    line-height: 1.2;
    margin: 0;
  }

  .jobs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .job-card {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.3s ease;
  }

  .job-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .job-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #000001;
    margin: 0;
    line-height: 1.3;
  }

  .job-type {
    font-size: 0.875rem;
    font-weight: 600;
    color: #dc2626;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .job-responsibilities {
    font-size: 1rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .job-button {
    display: inline-block;
    background: #000001;
    color: white;
    padding: 0.875rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .job-button:hover {
    background: #F7B32B;
    color: #000001;
    transform: translateY(-2px);
  }

  @media (max-width: 1024px) {
    .jobs-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .job-openings-section {
      padding: 4rem 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .jobs-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
