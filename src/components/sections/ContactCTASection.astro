---
interface Props {
  title?: string;
  titleEmphasis?: string;
  description?: string;
  primaryButtonText?: string;
  primaryButtonHref?: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
  cardTitle?: string;
  cardSubtitle?: string;
  cardButtonText?: string;
  cardButtonHref?: string;
  cardImage?: string;
  backgroundImage?: string;
  newsletterTitle?: string;
  newsletterDescription?: string;
}

const {
  title = "Your Electrical needs is our Top",
  titleEmphasis = "PRIORITY",
  description = "Professional electrical services available 24/7. Contact us today for a free consultation and let us handle all your electrical needs.",
  primaryButtonText = "Contact Us",
  primaryButtonHref = "/contact",
  secondaryButtonText = "Request a Call",
  secondaryButtonHref = "/request-call",
  cardTitle = "Let's",
  cardSubtitle = "Grow Together",
  cardButtonText = "Partner With Us",
  cardButtonHref = "/partnership",
  cardImage = "/images/raze-solar-GXLPLG3_Vf4-unsplash.jpg",
  backgroundImage = "/images/compagnons-yZmHFF-g-W0-unsplash.jpg",
  newsletterTitle = "Subscribe to our newsletter",
  newsletterDescription = "Stay updated with our latest news"
} = Astro.props;
---

<section class="contact-cta-section">
  <!-- Top Hero Section with Background -->
  <div class="hero-section" style={`background-image: url('${backgroundImage}');`}>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h2 class="hero-title">
        {title} <span class="title-emphasis">{titleEmphasis}</span>
      </h2>
      <p class="hero-description">{description}</p>
      <div class="hero-buttons">
        <a href={primaryButtonHref} class="hero-btn btn-outline">{primaryButtonText}</a>
        <a href={secondaryButtonHref} class="hero-btn btn-solid">{secondaryButtonText}</a>
      </div>
    </div>
  </div>

  <!-- Form and Card Section -->
  <div class="form-card-section">
    <div class="form-card-container">
      <!-- Contact Form -->
      <div class="contact-form-card">
        <div class="form-badge">Contact Form</div>
        <h3 class="form-title">Get in touch</h3>
        <form class="contact-form">
          <div class="form-row">
            <input type="text" placeholder="Name" required />
            <input type="text" placeholder="Company" />
          </div>
          <div class="form-row">
            <input type="email" placeholder="Email" required />
            <input type="tel" placeholder="Phone" />
          </div>
          <textarea placeholder="Write your message here" rows="4"></textarea>
          <button type="submit" class="form-submit">Submit It</button>
        </form>
      </div>

      <!-- Grow Together Card -->
      <div class="grow-card">
        <img src={cardImage} alt="Partnership" class="grow-image" />
        <div class="grow-overlay"></div>
        <div class="grow-content">
          <h3 class="grow-title">
            <span class="grow-lets">{cardTitle}</span><br />
            <span class="grow-main">{cardSubtitle}</span>
          </h3>
          <a href={cardButtonHref} class="grow-btn">
            {cardButtonText}
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Newsletter Section -->
  <div class="newsletter-wrapper">
    <div class="newsletter-section">
      <div class="newsletter-content">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        <div>
          <h3 class="newsletter-title">{newsletterTitle}</h3>
          <p class="newsletter-description">{newsletterDescription}</p>
        </div>
      </div>
      <form class="newsletter-form">
        <input type="email" placeholder="Enter your email address" required />
        <button type="submit">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-cta-section {
    position: relative;
    padding: 0;
    background: #f5f5f5;
  }

  /* Hero Section with Background */
  .hero-section {
    position: relative;
    background-size: cover;
    background-position: center;
    padding: 8rem 2rem 12rem 2rem;
    overflow: visible;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 20, 40, 0.85);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.2;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.02em;
  }

  .title-emphasis {
    color: #FFD700;
  }

  .hero-description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin: 0 0 2.5rem 0;
    max-width: 600px;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-btn {
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 2px solid;
  }

  .btn-outline {
    background: transparent;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
  }

  .btn-solid {
    background: #FFD700;
    color: #000000;
    border-color: #FFD700;
  }

  .btn-solid:hover {
    background: #FFA500;
    border-color: #FFA500;
    transform: translateY(-2px);
  }

  /* Form and Card Section */
  .form-card-section {
    position: relative;
    margin-top: -8rem;
    padding: 0 2rem 6rem 2rem;
  }

  .form-card-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  /* Contact Form */
  .contact-form-card {
    background: #ffffff;
    padding: 3rem;
    border-radius: 12px;
    border: 2px solid #e5e7eb;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  }

  .form-badge {
    display: inline-block;
    background: #FFD700;
    color: #000000;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #000000;
    margin: 0 0 2rem 0;
    line-height: 1.2;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .contact-form input,
  .contact-form textarea {
    padding: 1rem 1.25rem;
    border: 2px solid #e5e7eb;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    background: #f9fafb;
    transition: all 0.2s ease;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: #FFD700;
    background: white;
    box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.1);
  }

  .contact-form textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    background: #FFD700;
    color: #000000;
    border: 2px solid #FFD700;
    padding: 1.125rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.125rem;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 0.5rem;
  }

  .form-submit:hover {
    background: #FFA500;
    border-color: #FFA500;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 215, 0, 0.3);
  }

  /* Grow Together Card */
  .grow-card {
    background: #1a2332;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  .grow-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .grow-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.7));
    z-index: 1;
  }

  .grow-content {
    position: relative;
    z-index: 2;
    padding: 3rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .grow-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 2rem 0;
  }

  .grow-lets {
    color: #FFD700;
    display: block;
  }

  .grow-main {
    color: #ffffff;
    display: block;
  }

  .grow-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: transparent;
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.4);
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s ease;
    width: fit-content;
  }

  .grow-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
    transform: translateX(4px);
  }

  .grow-btn svg {
    transition: transform 0.2s ease;
  }

  .grow-btn:hover svg {
    transform: translateX(4px);
  }

  /* Newsletter */
  .newsletter-wrapper {
    padding: 0 2rem 6rem 2rem;
  }

  .newsletter-section {
    max-width: 1400px;
    margin: 0 auto;
    background: #1a2332;
    padding: 2.5rem 3rem;
    border-radius: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  .newsletter-content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .newsletter-content svg {
    color: #FFD700;
    flex-shrink: 0;
  }

  .newsletter-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.25rem 0;
  }

  .newsletter-description {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    gap: 0;
    max-width: 450px;
    flex: 1;
  }

  .newsletter-form input {
    flex: 1;
    padding: 1rem 1.5rem;
    border: 2px solid #e5e7eb;
    border-right: none;
    border-radius: 8px 0 0 8px;
    font-size: 1rem;
    background: white;
    font-weight: 500;
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: #FFD700;
  }

  .newsletter-form button {
    padding: 1rem 1.75rem;
    background: #FFD700;
    border: 2px solid #FFD700;
    border-radius: 0 8px 8px 0;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .newsletter-form button svg {
    color: #000000;
  }

  .newsletter-form button:hover {
    background: #FFA500;
    border-color: #FFA500;
  }

  @media (max-width: 1024px) {
    .form-card-container {
      grid-template-columns: 1fr;
    }

    .hero-section {
      padding: 6rem 2rem 10rem 2rem;
    }

    .form-card-section {
      margin-top: -6rem;
    }
  }

  @media (max-width: 768px) {
    .newsletter-section {
      flex-direction: column;
      align-items: flex-start;
      padding: 2rem 1.5rem;
    }

    .newsletter-form {
      width: 100%;
      max-width: none;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .hero-title {
      font-size: 2rem;
    }

    .grow-title {
      font-size: 2rem;
    }

    .form-title {
      font-size: 1.75rem;
    }
  }
</style>
