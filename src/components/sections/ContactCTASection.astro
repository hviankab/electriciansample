---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  contactInfo?: string;
  phoneLabel?: string;
  phoneNumber?: string;
  backgroundImage?: string;
}

const {
  eyebrow = "GET A FREE QUOTE",
  title = "Looking for Reliable Electrical Maintenance Services?",
  description = "Donec vel habitant montes at pharetra hac pellentesque proin ut. Mollis tenderit phasellus curabitur arcu massa ultricies. Massa pharetra velit uctus molestie erat eleifend mi.",
  contactInfo = "We will get back to you within 24 hours, or you can call us everyday at 09.00 AM - 11.00 PM",
  phoneLabel = "Call Us For Electrical Problems",
  phoneNumber = "+1 (555) 987-6543",
  backgroundImage = "/electricianimgs/jimmy-nilsson-masth-UovTD1dG-lA-unsplash.jpg"
} = Astro.props;
---

<section class="contact-cta-section" style={`background-image: url('${backgroundImage}');`}>
  <div class="contact-overlay"></div>
  <div class="contact-container">
    <div class="contact-layout">
      <!-- Left: Content -->
      <div class="contact-content">
        <p class="contact-eyebrow">{eyebrow}</p>
        <h2 class="contact-title">{title}</h2>
        <p class="contact-description">{description}</p>
        <p class="contact-info">{contactInfo}</p>
        
        <div class="contact-phone">
          <div class="phone-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="phone-label">{phoneLabel}</p>
            <a href={`tel:${phoneNumber.replace(/\s/g, '')}`} class="phone-number">{phoneNumber}</a>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="contact-form-wrapper">
        <div class="form-header">
          <h3 class="form-title">Fulfill This Form</h3>
          <div class="form-underline"></div>
        </div>
        
        <form class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" placeholder="Full name" required />
            </div>
            <div class="form-group">
              <label>Company</label>
              <input type="text" placeholder="Company name" />
            </div>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label>Phone</label>
              <input type="tel" placeholder="Phone number" required />
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" placeholder="Email address" required />
            </div>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label>Date</label>
              <input type="date" placeholder="Date" />
            </div>
            <div class="form-group">
              <label>Time</label>
              <input type="time" placeholder="Time" />
            </div>
          </div>
          
          <div class="form-group">
            <label>Message</label>
            <textarea placeholder="Your message" rows="4"></textarea>
          </div>
          
          <button type="submit" class="form-submit">
            Get A Free Quote
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta-section {
    position: relative;
    padding: 3rem 2rem;
    background-size: cover;
    background-position: center;
    min-height: 400px;
  }

  .contact-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 35, 65, 0.92);
    z-index: 1;
  }

  .contact-container {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .contact-content {
    color: #ffffff;
  }

  .contact-eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1.5rem 0;
  }

  .contact-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.2;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.02em;
  }

  .contact-description {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin: 0 0 2rem 0;
  }

  .contact-info {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin: 0 0 2.5rem 0;
  }

  .contact-phone {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .phone-icon {
    width: 56px;
    height: 56px;
    background: #FFD700;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .phone-icon svg {
    color: #ffffff;
  }

  .phone-label {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 0.25rem 0;
  }

  .phone-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .phone-number:hover {
    color: #FFD700;
  }

  .contact-form-wrapper {
    background: #ffffff;
    padding: 1.75rem;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  .form-header {
    margin-bottom: 1.25rem;
  }

  .form-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #000000;
    margin: 0 0 0.5rem 0;
  }

  .form-underline {
    width: 80px;
    height: 3px;
    background: #FFD700;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #000000;
  }

  .contact-form input,
  .contact-form textarea {
    padding: 0.75rem 0.875rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.875rem;
    background: #ffffff;
    transition: all 0.2s ease;
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: #9ca3af;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: #FFD700;
    box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.1);
  }

  .contact-form textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-submit {
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    color: #000000;
    border: none;
    padding: 0.875rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-submit:hover {
    background: #000000;
    color: #ffffff;
  }

  @media (max-width: 1024px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .contact-cta-section {
      padding: 4rem 1.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form-wrapper {
      padding: 2rem 1.5rem;
    }

    .phone-number {
      font-size: 1.25rem;
    }
  }
</style>
