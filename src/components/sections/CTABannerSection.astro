---
import { siteConfig } from "@/config/site"

interface Props {
  badge?: string;
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

const {
  badge = "GET STARTED",
  title,
  description,
  buttonText = "Get Started Today",
  buttonHref = "/contact",
  backgroundImage = "/images/hvac-hero.jpg"
} = Astro.props;
---

<section class="cta-section">
  <div class="cta-background" style={`background-image: url('${backgroundImage}');`}></div>
  <div class="cta-overlay"></div>
  <div class="cta-pattern"></div>
  
  <div class="cta-container">
    <div class="cta-content">
      {badge && (
        <div class="cta-badge">
          <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          <span>{badge}</span>
        </div>
      )}
      
      <h2 class="cta-title">{title}</h2>
      
      {description && (
        <p class="cta-description">{description}</p>
      )}
      
      <div class="cta-actions">
        <a href={buttonHref} class="cta-button cta-button-primary">
          <span>{buttonText}</span>
          <svg class="button-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        
        <a href={`tel:${siteConfig.contact.phone}`} class="cta-button cta-button-secondary">
          <svg class="button-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.13 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.04 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/>
          </svg>
          <span>Call Now</span>
        </a>
      </div>
      
      <div class="cta-features">
        <div class="feature-item">
          <svg class="feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
          <span>Free Estimates</span>
        </div>
        <div class="feature-item">
          <svg class="feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>24/7 Service</span>
        </div>
        <div class="feature-item">
          <svg class="feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span>Licensed & Insured</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding: 6rem 0;
    overflow: hidden;
  }

  .cta-background {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(18, 78, 102, 0.95) 0%, rgba(15, 62, 82, 0.92) 100%);
    z-index: 2;
  }

  .cta-pattern {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: 3;
  }

  .cta-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 4;
  }

  .cta-content {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: rgba(247, 179, 43, 0.15);
    border: 1px solid rgba(247, 179, 43, 0.3);
    border-radius: 50px;
    margin-bottom: 2rem;
    backdrop-filter: blur(10px);
  }

  .badge-icon {
    width: 1rem;
    height: 1rem;
    stroke: #F7B32B;
  }

  .cta-badge span {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #F7B32B;
  }

  .cta-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .cta-description {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.125rem 2.25rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .button-icon {
    width: 1.25rem;
    height: 1.25rem;
    transition: transform 0.3s ease;
  }

  .cta-button-primary {
    background: #F7B32B;
    color: #1a1a1a;
    box-shadow: 0 8px 30px rgba(247, 179, 43, 0.4);
  }

  .cta-button-primary:hover {
    background: #FFC857;
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(247, 179, 43, 0.5);
  }

  .cta-button-primary:hover .button-icon {
    transform: translateX(4px);
  }

  .cta-button-secondary {
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .cta-button-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-3px);
  }

  .cta-features {
    display: flex;
    gap: 2.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    font-weight: 500;
  }

  .feature-icon {
    width: 1.5rem;
    height: 1.5rem;
    stroke: #F7B32B;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cta-section {
      padding: 4rem 0;
    }

    .cta-container {
      padding: 0 1rem;
    }

    .cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .cta-button {
      width: 100%;
      justify-content: center;
    }

    .cta-features {
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }
  }

  /* Animation */
  .cta-content {
    animation: fadeInUp 0.8s ease;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
