---
interface TeamMember {
  name: string;
  role?: string;
  image: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  teamMembers?: TeamMember[];
}

const {
  eyebrow = "Our Team",
  title = "Our Creative people",
  description = "We are our best in every project. The value we provide to clients, business owners are based on our level of commitment, in-depth skills, knowledge and expertise. Rest assured, we take every project we take on.",
  teamMembers = [
    {
      name: "Juan Patrik",
      role: "Lead Electrician",
      image: "/images/raze-solar-GXLPLG3_Vf4-unsplash.jpg"
    },
    {
      name: "Helly Estrin",
      role: "Senior Technician",
      image: "/images/compagnons-yZmHFF-g-W0-unsplash.jpg"
    },
    {
      name: "Michel Jordan",
      role: "Project Manager",
      image: "/images/joseph-menjivar-lPG-hWlvGYU-unsplash.jpg"
    }
  ]
} = Astro.props;
---

<section class="our-team-section">
  <div class="team-container">
    <div class="team-layout">
      <!-- Left: Content -->
      <div class="team-content">
        <p class="team-eyebrow">{eyebrow}</p>
        <h2 class="team-title">{title}</h2>
        <p class="team-description">{description}</p>
      </div>

      <!-- Right: Team Cards -->
      <div class="team-cards-wrapper">
        <div class="yellow-bar"></div>
        <div class="team-cards">
          {teamMembers.map((member) => (
            <div class="team-card">
              <div class="card-image">
                <img src={member.image} alt={member.name} loading="lazy" />
              </div>
              <div class="card-info">
                <h3 class="member-name">{member.name}</h3>
                {member.role && <p class="member-role">{member.role}</p>}
                <div class="social-links">
                  <a href="#" class="social-link" aria-label="Facebook">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                    </svg>
                  </a>
                  <a href="#" class="social-link" aria-label="LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                      <rect width="4" height="12" x="2" y="9"/>
                      <circle cx="4" cy="4" r="2"/>
                    </svg>
                  </a>
                  <a href="#" class="social-link" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect width="20" height="20" x="2" y="2" rx="5"/>
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                      <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .our-team-section {
    padding: 5rem 2rem;
    background: #f5f5f5;
  }

  .team-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .team-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .team-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: center;
    align-items: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .team-eyebrow {
    font-size: 1rem;
    font-weight: 600;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .team-title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    color: #000000;
    line-height: 1.1;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .team-description {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
    font-weight: 400;
  }

  .team-cards-wrapper {
    position: relative;
    background: transparent;
    padding: 0;
  }

  .yellow-bar {
    display: none;
  }

  .team-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
  }

  .team-card {
    background: transparent;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    border: none;
    transition: all 0.3s ease;
    position: relative;
    cursor: pointer;
  }

  .team-card:first-child {
    margin-left: 0;
  }

  .team-card:last-child {
    margin-right: 0;
  }

  .team-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }

  .card-image {
    width: 100%;
    height: 450px;
    overflow: hidden;
    position: relative;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .team-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-info {
    position: absolute;
    inset: 0;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(33, 42, 49, 0.92);
    opacity: 0;
    transition: opacity 0.3s ease;
    gap: 1.5rem;
  }

  .team-card:hover .card-info {
    opacity: 1;
  }

  .member-name {
    font-size: 2rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    text-align: center;
  }

  .member-role {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    font-weight: 400;
    text-align: center;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .social-link {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
    text-decoration: none;
  }

  .social-link:hover {
    transform: scale(1.1);
  }

  .social-link svg {
    width: 24px;
    height: 24px;
    color: #212A31;
  }

  @media (max-width: 1200px) {
    .team-layout {
      gap: 3rem;
    }
  }

  @media (max-width: 900px) {
    .team-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .our-team-section {
      padding: 4rem 1.5rem;
    }

    .team-cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .card-image {
      height: 280px;
    }
  }
</style>
