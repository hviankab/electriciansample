---
interface TeamMember {
  name: string;
  role?: string;
  image: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  teamMembers?: TeamMember[];
}

const {
  eyebrow = "Our Team",
  title = "Our Creative people",
  description = "We are our best in every project. The value we provide to clients, business owners are based on our level of commitment, in-depth skills, knowledge and expertise. Rest assured, we take every project we take on.",
  teamMembers = [
    {
      name: "Juan Patrik",
      role: "Lead Electrician",
      image: "/images/raze-solar-GXLPLG3_Vf4-unsplash.jpg"
    },
    {
      name: "Helly Estrin",
      role: "Senior Technician",
      image: "/images/compagnons-yZmHFF-g-W0-unsplash.jpg"
    },
    {
      name: "Michel Jordan",
      role: "Project Manager",
      image: "/images/joseph-menjivar-lPG-hWlvGYU-unsplash.jpg"
    }
  ]
} = Astro.props;
---

<section class="our-team-section">
  <div class="team-container">
    <div class="team-layout">
      <!-- Left: Content -->
      <div class="team-content">
        <p class="team-eyebrow">{eyebrow}</p>
        <h2 class="team-title">{title}</h2>
        <p class="team-description">{description}</p>
        
        <div class="team-navigation">
          <button class="nav-btn prev-btn" aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <div class="nav-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
          <button class="nav-btn next-btn" aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Right: Team Cards -->
      <div class="team-cards-wrapper">
        <div class="yellow-bar"></div>
        <div class="team-cards">
          {teamMembers.map((member) => (
            <div class="team-card">
              <div class="card-image">
                <img src={member.image} alt={member.name} loading="lazy" />
              </div>
              <div class="card-info">
                <h3 class="member-name">{member.name}</h3>
                {member.role && <p class="member-role">{member.role}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .our-team-section {
    padding: 8rem 2rem;
    background: #f5f5f5;
  }

  .team-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .team-layout {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 4rem;
    align-items: center;
  }

  .team-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .team-eyebrow {
    font-size: 1rem;
    font-weight: 600;
    color: #FFD700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .team-title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    color: #000000;
    line-height: 1.1;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .team-description {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
    font-weight: 400;
  }

  .team-navigation {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .nav-btn {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    border: 2px solid #e5e7eb;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .nav-btn:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }

  .next-btn {
    background: #d4f4dd;
    border-color: #d4f4dd;
  }

  .next-btn:hover {
    background: #c0eacc;
    border-color: #c0eacc;
  }

  .nav-btn svg {
    color: #374151;
  }

  .nav-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d1d5db;
    transition: all 0.2s ease;
  }

  .dot.active {
    background: #374151;
    width: 24px;
    border-radius: 4px;
  }

  .team-cards-wrapper {
    position: relative;
    background: #FFD700;
    padding: 2rem 0;
  }

  .yellow-bar {
    display: none;
  }

  .team-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    position: relative;
  }

  .team-card {
    background: #1a1a1a;
    border-radius: 0;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    border: none;
    transition: all 0.3s ease;
    position: relative;
  }

  .team-card:first-child {
    margin-left: -2rem;
  }

  .team-card:last-child {
    margin-right: -2rem;
  }

  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
  }

  .card-image {
    width: 100%;
    height: 400px;
    overflow: hidden;
    background: #0a0a0a;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .team-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-info {
    padding: 1.5rem;
    text-align: center;
    background: #1a1a1a;
  }

  .member-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.25rem 0;
  }

  .member-role {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    font-weight: 400;
  }

  @media (max-width: 1200px) {
    .team-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .team-content {
      text-align: center;
      align-items: center;
    }

    .team-navigation {
      justify-content: center;
    }
  }

  @media (max-width: 900px) {
    .team-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .our-team-section {
      padding: 4rem 1.5rem;
    }

    .team-cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .card-image {
      height: 280px;
    }
  }
</style>
