---
interface Project {
  title: string;
  category: string;
  description: string;
  image: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  projects?: Project[];
  buttonText?: string;
  buttonHref?: string;
}

const {
  eyebrow = "EXPLORE SERVICES",
  title = "Our Electrical Services",
  description = "Comprehensive solutions for homes and businesses, delivered with safety, efficiency, and precision.",
  projects = [
    {
      title: "Electrical Installation",
      category: "Installation",
      description: "Complete electrical setups for new homes and businesses, ensuring safe [...]",
      image: "/electricianimgs/AdobeStock_136089970.jpeg",
      href: "/services/electrical-installation"
    },
    {
      title: "Wiring & Rewiring",
      category: "Wiring",
      description: "Upgrade or repair outdated wiring with modern solutions that improve safety [...]",
      image: "/electricianimgs/AdobeStock_187924476.jpeg",
      href: "/services/wiring-rewiring"
    },
    {
      title: "Lighting Solutions",
      category: "Lighting",
      description: "Design and install indoor, outdoor, and smart lighting systems to enhance [...]",
      image: "/electricianimgs/AdobeStock_208314515.jpeg",
      href: "/services/lighting-solutions"
    },
    {
      title: "Panel Upgrades",
      category: "Upgrades",
      description: "Modernize your electrical panel to handle increased power demands [...]",
      image: "/electricianimgs/AdobeStock_327681318.jpeg",
      href: "/services/panel-upgrades"
    },
    {
      title: "Emergency Repairs",
      category: "Emergency",
      description: "24/7 emergency electrical services to address urgent issues [...]",
      image: "/electricianimgs/AdobeStock_439136266.jpeg",
      href: "/services/emergency-repairs"
    },
    {
      title: "Safety Inspections",
      category: "Inspection",
      description: "Comprehensive electrical safety inspections for residential and commercial [...]",
      image: "/electricianimgs/AdobeStock_543922851.jpeg",
      href: "/services/safety-inspections"
    }
  ],
  buttonText = "VIEW ALL SERVICES",
  buttonHref = "/services"
} = Astro.props;
---

<section class="our-projects-section">
  <div class="projects-container">
    <!-- Header -->
    <div class="projects-header">
      <div class="header-content">
        <p class="projects-eyebrow">{eyebrow}</p>
        <h2 class="projects-title">{title}</h2>
        <p class="projects-description">{description}</p>
      </div>
      <a href={buttonHref} class="view-all-btn">
        {buttonText}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Projects Grid -->
    <div class="projects-grid">
      {projects.map((project) => (
        <a href={project.href} class="project-card">
          <div class="project-image">
            <img src={project.image} alt={project.title} loading="lazy" />
          </div>
          <div class="project-info">
            <h3 class="project-title">{project.title}</h3>
            <p class="project-description">{project.description}</p>
            <div class="project-arrow">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .our-projects-section {
    padding: 5rem 2rem;
    background: #f8f9fa;
  }

  .projects-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .projects-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
    gap: 2rem;
  }

  .header-content {
    flex: 1;
  }

  .projects-eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.75rem 0;
  }

  .projects-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #000000;
    line-height: 1.2;
    margin: 0 0 0.75rem 0;
    letter-spacing: -0.02em;
  }

  .projects-description {
    font-size: 1rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    font-weight: 400;
  }

  .view-all-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    color: #000000;
    border: none;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .view-all-btn:hover {
    background: #000000;
    color: #ffffff;
  }

  .view-all-btn svg {
    display: none;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .project-card {
    background: #ffffff;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .project-image {
    position: relative;
    height: 240px;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
    position: relative;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #000000;
    margin: 0;
    line-height: 1.3;
  }

  .project-description {
    font-size: 0.9375rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .project-arrow {
    width: 32px;
    height: 32px;
    background: transparent;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s ease;
    border: none;
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
  }

  .project-arrow svg {
    color: #9ca3af;
    transition: all 0.2s ease;
  }

  .project-card:hover .project-arrow svg {
    color: #000000;
    transform: translate(2px, -2px);
  }

  @media (max-width: 1024px) {
    .projects-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .view-all-btn {
      align-self: flex-start;
    }

    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .our-projects-section {
      padding: 4rem 1.5rem;
    }

    .projects-header {
      margin-bottom: 2.5rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .project-image {
      height: 220px;
    }
  }
</style>
