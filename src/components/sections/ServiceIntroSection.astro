---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  image?: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
}

const {
  eyebrow = "OUR SERVICES",
  title,
  description,
  image = "/electricianimgs/electrician-working-near-board-with-wires-installation-connection-electrics.jpg",
  features = [],
  buttonText,
  buttonHref = "/contact"
} = Astro.props;
---

<section class="service-intro">
  <div class="service-container">
    
    <div class="intro-grid">
      <!-- Left: Image -->
      <div class="image-side">
        <div class="image-wrapper">
          <img src={image} alt={title} loading="lazy" />
          <div class="image-gradient"></div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="content-side">
        <div class="eyebrow-badge">{eyebrow}</div>
        
        <h2 class="intro-title">{title}</h2>
        
        <p class="intro-description">{description}</p>
        
        {features.length > 0 && (
          <div class="features-list">
            {features.map((feature) => (
              <div class="feature-item">
                <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>{feature}</span>
              </div>
            ))}
          </div>
        )}
        
        {buttonText && (
          <a href={buttonHref} class="intro-button">
            {buttonText}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        )}
      </div>
    </div>

  </div>
</section>

<style>
  .service-intro {
    padding: 5rem 2rem;
    background: #f8f9fa;
  }

  .service-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 45% 55%;
    gap: 4rem;
    align-items: center;
  }

  .image-side {
    position: relative;
  }

  .image-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 3/4;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.4) 100%);
  }

  .content-side {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .eyebrow-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #000000;
    padding: 0.5rem 1rem;
    background: #ffffff;
    border-radius: 20px;
    width: fit-content;
  }

  .intro-title {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.2;
    margin: 0;
  }

  .intro-description {
    font-size: 1rem;
    color: #4a4a4a;
    line-height: 1.7;
    margin: 0;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .check-icon {
    flex-shrink: 0;
    margin-top: 0.125rem;
    color: #FFD700;
  }

  .feature-item span {
    font-size: 0.95rem;
    color: #333333;
    line-height: 1.6;
  }

  .intro-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    width: fit-content;
    margin-top: 0.5rem;
  }

  .intro-button:hover {
    background: #000000;
    color: #ffffff;
  }

  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .image-wrapper {
      aspect-ratio: 16/10;
    }
  }

  @media (max-width: 768px) {
    .service-intro {
      padding: 4rem 1.5rem;
    }

    .intro-grid {
      gap: 2rem;
    }
  }
</style>
