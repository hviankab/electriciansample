---
interface Card {
  title: string;
  subtitle?: string;
  description: string;
  price?: string;
  priceLabel?: string;
  buttonText: string;
  buttonHref: string;
  image: string;
  badge?: string;
}

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;
---

<section class="promo-cards-section" style={`
  --bg-image-1: url(${cards[0]?.image});
  --bg-image-2: url(${cards[1]?.image});
  --bg-image-3: url(${cards[2]?.image});
`}>
  <div class="container">
    <div class="cards-grid">
      {cards.map((card) => (
        <div class="promo-card">
          <div class="card-inner">
            <div class="card-content">
              {card.badge && <div class="card-badge">{card.badge}</div>}
              
              <h3 class="card-title">{card.title}</h3>
              {card.subtitle && <p class="card-subtitle">{card.subtitle}</p>}
              
              {card.price && (
                <div class="price-box">
                  <div class="price">{card.price}</div>
                  {card.priceLabel && <div class="price-label">{card.priceLabel}</div>}
                </div>
              )}
              
              <p class="card-description">{card.description}</p>
              
              <a href={card.buttonHref} class="card-button">BOOK NOW</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .promo-cards-section {
    padding: 5rem 0;
    background: #fff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .promo-card {
    position: relative;
    height: 450px;
  }

  .card-inner {
    position: relative;
    height: 100%;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border: 3px dashed #FFD700;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    z-index: 0;
  }

  .promo-card:nth-child(1) .card-inner::before {
    background-image: var(--bg-image-1);
  }

  .promo-card:nth-child(2) .card-inner::before {
    background-image: var(--bg-image-2);
  }

  .promo-card:nth-child(3) .card-inner::before {
    background-image: var(--bg-image-3);
  }

  .card-inner:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
  }

  .card-badge {
    background: #000;
    color: #FFD700;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .card-content {
    position: relative;
    z-index: 2;
    padding: 2.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .card-title {
    font-size: 2rem;
    font-weight: 800;
    color: #000;
    margin: 0 0 0.75rem 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .card-subtitle {
    font-size: 1rem;
    color: #666;
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .price-box {
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    padding: 1.5rem;
    border-radius: 12px;
    margin: 0 0 1.5rem 0;
    text-align: center;
    width: 100%;
    border: none;
  }

  .price {
    font-size: 2.5rem;
    font-weight: 900;
    color: #000;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .price-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #000;
    text-transform: uppercase;
  }

  .card-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #333;
    margin: 0 0 auto 0;
    width: 100%;
  }

  .card-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: #000;
    color: #FFD700;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 50px;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 1.5rem;
    width: 100%;
  }

  .card-button:hover {
    background: #FFD700;
    color: #000;
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .promo-cards-section {
      padding: 3rem 0;
    }

    .cards-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .promo-card {
      height: 400px;
    }

    .card-title {
      font-size: 1.5rem;
    }

    .price {
      font-size: 2rem;
    }
  }
</style>
