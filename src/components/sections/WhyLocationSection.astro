---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  location: string;
  description: string;
  image: string;
  features: Feature[];
}

const {
  eyebrow = "SERVICE AREAS",
  title,
  location,
  description,
  image,
  features
} = Astro.props;
---

<section class="why-location-section">
  <div class="container">
    <!-- Top Content -->
    <div class="top-content">
      {eyebrow && <div class="eyebrow">{eyebrow}</div>}
      <h2 class="main-title">{title} <span class="location-highlight">{location}</span></h2>
      <p class="description">{description}</p>
    </div>

    <!-- Bottom Grid -->
    <div class="content-grid">
      <!-- Left: Image -->
      <div class="image-wrapper">
        <img src={image} alt={`Electrical services in ${location}`} />
      </div>

      <!-- Right: Features -->
      <div class="features-wrapper">
        <h3 class="features-title">Why {location} Residents Trust Us</h3>
        <div class="features-list">
          {features.map((feature) => (
            <div class="feature-item">
              <div class="feature-icon">{feature.icon}</div>
              <div class="feature-content">
                <h4 class="feature-title">{feature.title}</h4>
                <p class="feature-description">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-location-section {
    padding: 5rem 0;
    background: #fff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Top Content */
  .top-content {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 4rem;
  }

  .eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #000;
    text-transform: uppercase;
    margin-bottom: 1rem;
    text-align: center !important;
    display: block;
    width: 100%;
  }

  .main-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 1.5rem 0;
    line-height: 1.2;
  }

  .location-highlight {
    color: #000;
  }

  .description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #4a5568;
    margin: 0;
  }

  /* Content Grid */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* Image */
  .image-wrapper {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  }

  .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Features */
  .features-wrapper {
    padding: 2rem 0;
  }

  .features-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 2rem 0;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .feature-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .feature-icon {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    background: #e0f2fe;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }

  .feature-content {
    flex: 1;
  }

  .feature-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem 0;
  }

  .feature-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #4a5568;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .image-wrapper {
      order: 2;
    }

    .features-wrapper {
      order: 1;
    }
  }

  @media (max-width: 640px) {
    .why-location-section {
      padding: 3rem 0;
    }

    .top-content {
      margin-bottom: 3rem;
    }

    .features-title {
      font-size: 1.5rem;
    }

    .feature-icon {
      width: 40px;
      height: 40px;
      font-size: 1.25rem;
    }

    .feature-item {
      gap: 1rem;
    }
  }
</style>
