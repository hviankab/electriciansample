---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  benefits?: { title: string; description: string }[];
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  imageCaption?: string;
}

const {
  eyebrow = "FLEXIBLE HVAC FINANCING OPTIONS",
  title = "Get a New HVAC System Without Breaking the Bank",
  description = "Upgrade your home comfort with our flexible HVAC financing options, designed to make a new heating and cooling system affordable for any budget. Whether you're facing an urgent HVAC replacement or looking to upgrade for energy efficiency, our financing plans offer low monthly payments and competitive rates to help you stay comfortable year-round. Avoid the upfront cost and spread out payments with ease—our fast, hassle-free application process makes it simple.",
  benefits = [
    {
      title: "Affordable Monthly Payments:",
      description: "Low, manageable payments to fit your budget."
    },
    {
      title: "Fast Approval Process",
      description: "Quick approval for immediate comfort upgrades."
    },
    {
      title: "And many more benefits",
      description: ""
    }
  ],
  buttonText = "LEARN MORE",
  buttonHref = "/financing",
  image = "/images/hvac.jpg",
  imageCaption = "HVAC Financing Solutions"
} = Astro.props;
---

<section class="financing-section">
  <div class="container mx-auto px-4">
    <div class="content-grid">
      
      <!-- Left: Content -->
      <div class="text-column" data-animate="fade-right">
        <div class="eyebrow">
          <span>{eyebrow}</span>
        </div>
        
        <h2 class="section-title">{title}</h2>
        
        <p class="section-description">{description}</p>

        <h3 class="benefits-title">Why Choose Our HVAC Financing Solutions?</h3>

        <!-- Benefits List -->
        <div class="benefits-list">
          {benefits.map((benefit) => (
            <div class="benefit-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 13l4 4L19 7" />
              </svg>
              <div class="benefit-content">
                <h4 class="benefit-title">{benefit.title}</h4>
                {benefit.description && <p class="benefit-description">{benefit.description}</p>}
              </div>
            </div>
          ))}
        </div>

        <!-- CTA Button -->
        {buttonText && buttonHref && (
          <div class="button-wrapper">
            <a href={buttonHref} class="cta-button">
              {buttonText}
            </a>
          </div>
        )}
      </div>

      <!-- Right: Image with Caption -->
      <div class="image-column" data-animate="fade-left">
        <div class="image-wrapper">
          <img 
            src={image}
            alt={imageCaption}
            class="financing-image"
          />
          <div class="image-caption">
            {imageCaption}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .financing-section {
    padding: 4rem 0;
    background: white;
    overflow: hidden;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ===== LEFT: Text Column ===== */
  .text-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.2;
    margin: 0;
  }

  .section-description {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #64748b;
    margin: 0;
  }

  .benefits-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e293b;
    margin: 1rem 0 0.5rem 0;
  }

  /* Benefits List */
  .benefits-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .check-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: #E3170A;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .benefit-content {
    flex: 1;
  }

  .benefit-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.25rem 0;
  }

  .benefit-description {
    font-size: 1rem;
    color: #64748b;
    margin: 0;
    line-height: 1.6;
  }

  /* CTA Button */
  .button-wrapper {
    margin-top: 1.5rem;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: #F7B32B;
    color: black;
    font-weight: 700;
    font-size: 1.0625rem;
    text-decoration: none;
    border-radius: 50px;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(247, 179, 43, 0.25);
    border: 1px solid #F7B32B;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cta-button:hover {
    color: #ffffff;
    border-color: #1a6b8a;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(169, 229, 187, 0.3);
  }

  /* ===== RIGHT: Image Column ===== */
  .image-column {
    position: relative;
  }

  .image-wrapper {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
    border: 8px solid #1e3a8a;
  }

  .financing-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .image-caption {
    background: #1e3a8a;
    color: white;
    text-align: center;
    padding: 1rem;
    font-weight: 600;
    font-size: 1rem;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .text-column {
      text-align: center;
      align-items: center;
    }

    .benefits-list {
      text-align: left;
      max-width: 600px;
    }

    .section-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .financing-section {
      padding: 3rem 0;
    }

    .section-title {
      font-size: 1.75rem;
    }

    .section-description {
      font-size: 0.95rem;
    }

    .benefits-title {
      font-size: 1.25rem;
    }
  }
</style>
