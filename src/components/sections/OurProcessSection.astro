---
interface Step {
  step: string;
  icon: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  steps: Step[];
}

const {
  eyebrow = "OUR PROCESS",
  title,
  description,
  steps
} = Astro.props;
---

<section class="process-section">
  <div class="process-container">
    <!-- Header -->
    <div class="process-header">
      <div class="badge-wrapper">
        <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
        <span>{eyebrow}</span>
      </div>
      
      <h2 class="process-title">{title}</h2>
      <div class="process-description" set:html={description} />
    </div>

    <!-- Steps -->
    <div class="steps-wrapper">
      {steps.map((step, index) => (
        <div class="step-card" data-index={index}>
          <div class="step-number-badge">
            <span class="step-number">{index + 1}</span>
          </div>
          
          <div class="step-icon-wrapper">
            <div class="step-icon-bg"></div>
            <img src={step.icon} alt={step.title} class="step-icon" />
          </div>
          
          <div class="step-content">
            <div class="step-label">{step.step}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
          
          {index < steps.length - 1 && (
            <div class="step-connector">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="process-cta">
      <div class="cta-content">
        <h3 class="cta-title">Ready to Get Started?</h3>
        <p class="cta-text">Contact us today to schedule your service or get a free estimate.</p>
      </div>
      <a href="/contact" class="cta-button">
        <span>Schedule Service</span>
        <svg class="button-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    position: relative;
  }

  .process-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .process-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .badge-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: linear-gradient(135deg, rgba(247, 179, 43, 0.1), rgba(247, 179, 43, 0.05));
    border: 1px solid rgba(247, 179, 43, 0.2);
    border-radius: 50px;
    margin-bottom: 1.5rem;
  }

  .badge-icon {
    width: 1rem;
    height: 1rem;
    stroke: #F7B32B;
  }

  .badge-wrapper span {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #D97706;
  }

  .process-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .process-description {
    font-size: 1.125rem;
    color: #64748b;
    line-height: 1.7;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Steps */
  .steps-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
    position: relative;
  }

  .step-card {
    background: white;
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e2e8f0;
    position: relative;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  .step-card[data-index="0"] { animation-delay: 0.1s; }
  .step-card[data-index="1"] { animation-delay: 0.3s; }
  .step-card[data-index="2"] { animation-delay: 0.5s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .step-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    border-color: #F7B32B;
  }

  .step-number-badge {
    position: absolute;
    top: -1rem;
    right: 2rem;
    width: 3rem;
    height: 3rem;
    background: linear-gradient(135deg, #F7B32B, #FFC857);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(247, 179, 43, 0.3);
  }

  .step-number {
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
  }

  .step-icon-wrapper {
    position: relative;
    width: 5rem;
    height: 5rem;
    margin-bottom: 1.5rem;
  }

  .step-icon-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #e0f2fe, #dbeafe);
    border-radius: 1.25rem;
    transform: rotate(45deg);
  }

  .step-icon {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
    z-index: 1;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-label {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #124E66;
  }

  .step-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
  }

  .step-description {
    font-size: 0.95rem;
    color: #64748b;
    line-height: 1.7;
  }

  .step-connector {
    display: none;
  }

  /* Bottom CTA */
  .process-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.5rem 3rem;
    background: linear-gradient(135deg, #124E66, #0f3e52);
    border-radius: 1.5rem;
    box-shadow: 0 10px 40px rgba(18, 78, 102, 0.2);
  }

  .cta-content {
    flex: 1;
  }

  .cta-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }

  .cta-text {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: #F7B32B;
    color: #1a1a1a;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    flex-shrink: 0;
    box-shadow: 0 4px 20px rgba(247, 179, 43, 0.3);
  }

  .cta-button:hover {
    background: #FFC857;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(247, 179, 43, 0.4);
  }

  .button-arrow {
    width: 1.125rem;
    height: 1.125rem;
    transition: transform 0.3s ease;
  }

  .cta-button:hover .button-arrow {
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .steps-wrapper {
      grid-template-columns: 1fr;
    }

    .process-cta {
      flex-direction: column;
      text-align: center;
      padding: 2rem;
    }
  }

  @media (max-width: 768px) {
    .process-section {
      padding: 4rem 0;
    }

    .process-container {
      padding: 0 1rem;
    }

    .step-card {
      padding: 2rem 1.5rem;
    }

    .cta-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
