---
interface Subcategory {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

interface Category {
  name: string;
  icon: string;
  subcategories: Subcategory[];
}

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  description?: string;
  categories?: Category[];
}

const {
  eyebrow = "OUR SERVICES",
  title = "Comprehensive Electrical",
  subtitle = "Solutions",
  description = "From residential repairs to commercial installations, we provide expert electrical services tailored to your needs.",
  categories = []
} = Astro.props;
---

<section class="all-services-section">
  <div class="all-services-container">
    <!-- Header -->
    <div class="services-header">
      {eyebrow && <div class="eyebrow-badge"><span>{eyebrow}</span></div>}
      <h2 class="services-title">
        {title} <span class="title-highlight">{subtitle}</span>
      </h2>
      {description && <p class="services-description">{description}</p>}
    </div>

    <!-- Tabs -->
    <div class="tabs-container">
      <div class="tabs-nav">
        {categories.map((category, index) => (
          <button 
            class={`tab-button ${index === 0 ? 'active' : ''}`}
            data-tab={`tab-${index}`}
          >
            <span class="tab-icon">{category.icon}</span>
            <span class="tab-name">{category.name}</span>
          </button>
        ))}
      </div>

      <div class="tabs-content">
        {categories.map((category, index) => (
          <div 
            class={`tab-panel ${index === 0 ? 'active' : ''}`}
            data-panel={`tab-${index}`}
          >
            <div class="services-grid">
              {category.subcategories.map((subcategory) => (
                <a href={subcategory.href || "#"} class="service-card">
                  <div class="service-icon">{subcategory.icon}</div>
                  <h3 class="service-title">{subcategory.title}</h3>
                  <p class="service-description">{subcategory.description}</p>
                  <div class="service-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const tabId = button.getAttribute('data-tab');

        // Remove active class from all buttons and panels
        tabButtons.forEach(btn => btn.classList.remove('active'));
        tabPanels.forEach(panel => panel.classList.remove('active'));

        // Add active class to clicked button and corresponding panel
        button.classList.add('active');
        const activePanel = document.querySelector(`.tab-panel[data-panel="${tabId}"]`);
        if (activePanel) {
          activePanel.classList.add('active');
        }
      });
    });
  });
</script>

<style>
  .all-services-section {
    padding: 6rem 2rem;
    background: #f9fafb;
    position: relative;
  }

  .all-services-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Header */
  .services-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow-badge {
    display: inline-block;
    margin-bottom: 1rem;
  }

  .eyebrow-badge span {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .services-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #000;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .title-highlight {
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .services-description {
    font-size: 1.125rem;
    color: #6b7280;
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Tabs */
  .tabs-container {
    margin-top: 3rem;
  }

  .tabs-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .tab-button {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 2rem;
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 180px;
  }

  .tab-button:hover {
    border-color: #FFA500;
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(255, 165, 0, 0.1);
  }

  .tab-button.active {
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    border-color: #FFA500;
    box-shadow: 0 8px 20px rgba(255, 165, 0, 0.2);
  }

  .tab-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .tab-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1f2937;
    text-align: center;
    line-height: 1.3;
  }

  .tab-button.active .tab-name {
    color: #000;
  }

  /* Tab Content */
  .tabs-content {
    position: relative;
  }

  .tab-panel {
    display: none;
    animation: fadeIn 0.4s ease;
  }

  .tab-panel.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-8px);
    border-color: #FFA500;
    box-shadow: 0 12px 32px rgba(255, 165, 0, 0.15);
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  .service-icon {
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .service-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #000;
    margin: 0;
    line-height: 1.3;
  }

  .service-description {
    font-size: 0.95rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .service-arrow {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    color: #FFA500;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .service-card:hover .service-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .all-services-section {
      padding: 4rem 1.5rem;
    }

    .services-header {
      margin-bottom: 2rem;
    }

    .tabs-nav {
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .tab-button {
      min-width: 140px;
      padding: 1.25rem 1.5rem;
    }

    .tab-icon {
      font-size: 2rem;
    }

    .tab-name {
      font-size: 0.875rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .service-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
