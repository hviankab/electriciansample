---
import HeroPage from "@/components/sections/HeroPage.astro"
import ServiceAreaSection from "@/components/sections/ServiceAreaSection.astro"
import LocationIntroSection from "@/components/sections/LocationIntroSection.astro"
import ServiceCardsGridSection from "@/components/sections/ServiceCardsGridSection.astro"
import PortfolioSection from "@/components/sections/PortfolioSection.astro"
import FAQSection from "@/components/sections/FAQSection.astro"

interface Props {
  cityName: string;
  mapAddress: string;
  backgroundImage?: string;
}

const { cityName, mapAddress, backgroundImage = "/images/download (73).avif" } = Astro.props;
---

<HeroPage
  title={cityName}
  subtitle={`Providing expert electrical solutions to homes and businesses in ${cityName} — ensuring reliable and efficient electrical services every time. Call us for expert assistance!`}
  buttonText="SCHEDULE SERVICE"
  buttonHref="/contact"
  backgroundImage={backgroundImage}
  trustIndicators={[
    "Serving Our Community for 20 Years",
    "Quality Service",
    "24-Hour Emergency Service Available"
  ]}
/>

<ServiceAreaSection
  title="Electrical Solutions in Your Area"
  description=""
  areas={[
    "Santa Monica", "Pasadena", "Glendale", "Downtown {city}", "Hollywood",
    "Beverly Hills", "Venice", "Westwood", "Culver City", "San Fernando Valley",
    "Studio City", "North Hollywood", "Sherman Oaks", "Encino", "Burbank",
    "Torrance", "Long Beach", "Inglewood", "El Segundo", "Brentwood",
    "Silver Lake", "Echo Park", "Hancock Park", "Marina del Rey", "Manhattan Beach"
  ]}
  mapAddress={mapAddress}
  variant="full"
/>

<LocationIntroSection
  badge="Residential & Commercial"
  title={`RELIABLE ELECTRICAL SERVICES IN ${cityName.toUpperCase()}`}
  description={`{business} is proud to provide top-tier electrical services across ${cityName}. Whether you're in the coastal neighborhoods, downtown area, or residential districts, our expert electricians are here to ensure your safety and power needs in every season. With a commitment to quality and efficiency, we're the trusted choice for ${cityName}'s residents and businesses.`}
  highlights={["residential electrical", "commercial electrical", "emergency repairs", "maintenance plans"]}
  serviceArea={`From system installations to emergency repairs, we offer a full range of electrical and power services.`}
  guaranteeText="We prioritize your satisfaction with prompt responses, transparent pricing, and reliable service. When you need professional electrical services, we guarantee to fix it right the first time or return at our expense - that's our satisfaction promise to you!"
  infoBoxText={`We service the entirety of ${cityName} and all surrounding areas within a 50km radius. Our team of trusted master electricians has an impeccable reputation throughout the region. Contact our professional electrical team today for expert service you can count on!`}
  buttonText="TALK TO AN ELECTRICIAN NOW"
  buttonHref="/contact"
  image="/newimages/download - 2026-03-25T161755.081.avif"
  imageAlt="Electrician at Work"
/>

<CouponsSection
  title="Specials and Offers"
  coupons={[
    { label: "First-Time Customers", discount: "$100 OFF", description: "Electrical Panel Upgrade for first-time customers only" },
    { label: "Repair Special", discount: "$150 OFF", description: "Save $150 on Any Repair. Valid for repairs over $500" },
    { label: "Maintenance", discount: "$25 OFF", description: "Your Electrical System Inspection. Limited time offer" }
  ]}
/>

<ServiceCardsGridSection
  badge="OUR SERVICES"
  title={`Complete Electrical Services for ${cityName}`}
  description={`We provide comprehensive electrical solutions for homes and businesses in ${cityName}. Our certified electricians are ready to handle all your electrical needs.`}
  tabs={[
    {
      id: "residential",
      title: "Residential Electrical",
      heading: "Professional Residential Electrical Services",
      description: `Keep your ${cityName} home safe and powered with our comprehensive electrical services.`,
      image: "/newimages/download - 2026-03-25T161858.938.avif",
      services: [
        {
          icon: "⚡",
          title: "Electrical Repairs",
          href: "/residential-electrical"
        },
        {
          icon: "🔧",
          title: "Electrical Maintenance",
          href: "/residential-electrical"
        },
        {
          icon: "🏠",
          title: "Panel Upgrades",
          href: "/residential-electrical"
        },
        {
          icon: "💡",
          title: "Lighting Installation",
          href: "/residential-electrical"
        }
      ],
      buttonText: "View Residential Services",
      buttonHref: "/residential-electrical"
    },
    {
      id: "commercial",
      title: "Commercial Electrical",
      heading: "Commercial Electrical Services",
      description: `Reliable electrical solutions to keep your ${cityName} business running smoothly.`,
      image: "/newimages/download - 2026-03-25T161847.589.avif",
      services: [
        {
          icon: "🏢",
          title: "Commercial Wiring",
          href: "/commercial-electrical"
        },
        {
          icon: "⚙️",
          title: "Electrical Maintenance",
          href: "/commercial-electrical"
        },
        {
          icon: "🔌",
          title: "Power Distribution",
          href: "/commercial-electrical"
        },
        {
          icon: "💡",
          title: "Commercial Lighting",
          href: "/commercial-electrical"
        }
      ],
      buttonText: "View Commercial Services",
      buttonHref: "/commercial-electrical"
    },
    {
      id: "specialty",
      title: "Specialty Services",
      heading: "Specialty Electrical Services",
      description: `Specialized electrical solutions for unique needs.`,
      image: "/newimages/download - 2026-03-25T161755.081.avif",
      services: [
        {
          icon: "🚗",
          title: "EV Charging Stations",
          href: "/specialty-services"
        },
        {
          icon: "🌟",
          title: "Landscape Lighting",
          href: "/specialty-services/landscape-lighting"
        },
        {
          icon: "🏊",
          title: "Pool & Spa Electrical",
          href: "/specialty-services/pool-spa-electrical"
        },
        {
          icon: "🎄",
          title: "Holiday Lighting",
          href: "/specialty-services/holiday-lighting"
        }
      ],
      buttonText: "View Specialty Services",
      buttonHref: "/specialty-services"
    },
    {
      id: "emergency",
      title: "Emergency Electrical",
      heading: "24/7 Emergency Electrical Services",
      description: "Electrical emergencies don't wait for business hours. Our emergency response team is available 24/7.",
      image: "/newimages/download - 2026-03-25T161804.399.avif",
      services: [
        {
          icon: "🚨",
          title: "24/7 Power Outages",
          href: "/emergency"
        },
        {
          icon: "🔥",
          title: "24/7 Electrical Fires",
          href: "/emergency"
        },
        {
          icon: "⚡",
          title: "24/7 Emergency Repairs",
          href: "/emergency"
        }
      ],
      buttonText: "Get Emergency Service",
      buttonHref: "/emergency"
    }
  ]}
/>

<FAQSection
  badge="FAQ"
  title={`Electrical Questions for ${cityName} Residents`}
  subtitle="Get answers to common electrical questions"
  faqs={[
    {
      question: `Do you provide same-day service in ${cityName}?`,
      answer: `Yes! We offer same-day electrical service throughout ${cityName} for most repairs and maintenance. Contact us early in the day for the best availability.`
    },
    {
      question: "What electrical brands do you work with?",
      answer: "We work with all major electrical brands including Square D, Siemens, GE, Eaton, Leviton, and more. Our electricians are trained to service and install any brand."
    },
    {
      question: "How much does a new electrical panel cost?",
      answer: "Electrical panel costs vary based on size, amperage rating, and installation complexity. We offer free estimates and can help you find a system that fits your budget and needs."
    },
    {
      question: "Do you offer maintenance plans?",
      answer: "Yes! Our maintenance plans include bi-annual inspections, priority scheduling, discounts on repairs, and extended warranties. Join today to keep your system running safely."
    },
    {
      question: "What payment methods do you accept?",
      answer: "We accept all major credit cards, checks, and cash. We also offer flexible financing options to make electrical services affordable for everyone."
    }
  ]}
/>

<PortfolioSection
  badge="GALLERY"
  title="See Our Quality Work"
  images={[
    "/images/tekton-ndJlw4Bz-1Y-unsplash (1).jpg",
    "/images/raymond-yeung--BWDRf_mG9Q-unsplash.jpg",
    "/images/hvac.jpg",
    "/images/hvac-hero.jpg",
    "/images/compagnons-yZmHFF-g-W0-unsplash.jpg",
    "/images/hvac-technician-refilling-freon.jpg"
  ]}
  links={[
    "/residential-electrical",
    "/commercial-electrical",
    "/residential-electrical",
    "/commercial-electrical",
    "/emergency",
    "/emergency"
  ]}
  labels={[
    "Residential Electrical",
    "Commercial Electrical",
    "Panel Upgrades",
    "Commercial Lighting",
    "24/7 Emergency Service",
    "24/7 Emergency Repairs"
  ]}
/>
