---
import { getEntry } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import HeroSection from "@/components/sections/HeroSection.astro"
import TrustBadgesSection from "@/components/sections/TrustBadgesSection.astro"
import LogoCarouselSection from "@/components/sections/LogoCarouselSection.astro"
import WhoWeAreSection from "@/components/sections/WhoWeAreSection.astro"
import WhyChooseSection from "@/components/sections/WhyChooseSection.astro"
import PricingSection from "@/components/sections/PricingSection.astro"
import ServicesGridSection from "@/components/sections/ServicesGridSection.astro"
import ServiceCardsGridSection from "@/components/sections/ServiceCardsGridSection.astro"
import OurCreativeTeamSection from "@/components/sections/OurCreativeTeamSection.astro"
import OurProjectsSection from "@/components/sections/OurProjectsSection.astro"
import TestimonialsSection from "@/components/sections/TestimonialsSection.astro"
import FAQAccordionSection from "@/components/sections/FAQAccordionSection.astro"
import ContactCTASection from "@/components/sections/ContactCTASection.astro"
import CouponsSection from "@/components/sections/CouponsSection.astro"
import InstagramGallerySection from "@/components/sections/InstagramGallerySection.astro"

const page = await getEntry("pages", "index")
if (!page) throw new Error("index.json not found in src/content/pages/")

const componentMap = {
  HeroSection,
  TrustBadgesSection,
  LogoCarouselSection,
  WhoWeAreSection,
  WhyChooseSection,
  PricingSection,
  ServicesGridSection,
  ServiceCardsGridSection,
  OurCreativeTeamSection,
  OurProjectsSection,
  TestimonialsSection,
  FAQAccordionSection,
  ContactCTASection,
  CouponsSection,
  InstagramGallerySection,
}
---

<BaseLayout 
  title={page.data.title} 
  description={page.data.description}
  keywords={page.data.keywords}
  ogImage={page.data.ogImage}
>
  {page.data.sections.map((section) => {
    const Component = componentMap[section.component as keyof typeof componentMap]
    return Component ? <Component {...section.props} /> : null
  })}
</BaseLayout>
