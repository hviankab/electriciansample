---
import { getCollection } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import HeroPage from "@/components/sections/HeroPage.astro"
import ServiceIntroSection from "@/components/sections/ServiceIntroSection.astro"
import WhyChooseSection from "@/components/sections/WhyChooseSection.astro"
import ServicesGridSection from "@/components/sections/ServicesGridSection.astro"
import OurProjectsSection from "@/components/sections/OurProjectsSection.astro"
import TestimonialsSection from "@/components/sections/TestimonialsSection.astro"
import ContactCTASection from "@/components/sections/ContactCTASection.astro"
import FAQAccordionSection from "@/components/sections/FAQAccordionSection.astro"

const componentMap = {
  HeroPage,
  ServiceIntroSection,
  WhyChooseSection,
  ServicesGridSection,
  OurProjectsSection,
  TestimonialsSection,
  ContactCTASection,
  FAQAccordionSection,
}

export async function getStaticPaths() {
  const pages = await getCollection("pages")
  return pages
    .filter(page => !page.id.startsWith("index") && page.id.includes("/") && !page.data.draft)
    .map((page) => {
      const slug = page.id.replace(/\.json?$/, '')
      return {
        params: { slug },
        props: { page },
      }
    })
}

const { page } = Astro.props
---

<BaseLayout 
  title={page.data.title} 
  description={page.data.description}
  keywords={page.data.keywords}
  ogImage={page.data.ogImage}
  noindex={page.data.noindex}
>
  {page.data.sections.map((section) => {
    const Component = componentMap[section.component as keyof typeof componentMap]
    return Component ? <Component {...section.props} /> : null
  })}
</BaseLayout>
